<Window x:Class="Ven4Tools.Views.ConsentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Помогите улучшить Ven4Tools" Height="550" Width="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Background="#2D2D30">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="📊 Помогите улучшить каталог приложений" 
                   FontSize="16" FontWeight="Bold" Foreground="#4CAF50" 
                   Margin="0,0,0,15"/>
        
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#DDD" Margin="0,0,0,15">
            Вы можете добавлять свои приложения в каталог. Это поможет нам
            понять, какие программы нужны пользователям.
        </TextBlock>
        
        <Border Grid.Row="2" Background="#252526" CornerRadius="5" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="✅ Если вы согласитесь:" Foreground="#4CAF50" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBlock Text="• Анонимная статистика поможет определить популярные приложения" Foreground="#DDD" Margin="20,0,0,2"/>
                <TextBlock Text="• Популярные приложения будут добавлены в основной каталог" Foreground="#DDD" Margin="20,0,0,2"/>
                <TextBlock Text="• Вы получите их автоматически" Foreground="#DDD" Margin="20,0,0,5"/>
                
                <TextBlock Text="❌ Если вы откажетесь:" Foreground="#FFA500" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <TextBlock Text="• Вы по-прежнему сможете добавлять свои приложения" Foreground="#DDD" Margin="20,0,0,2"/>
                <TextBlock Text="• Основной каталог будет обновляться как обычно" Foreground="#DDD" Margin="20,0,0,2"/>
                <TextBlock Text="• Статистика НЕ будет собираться" Foreground="#DDD" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>
        
        <TextBlock Grid.Row="3" Text="🔒 Никакие личные данные не передаются. Отправляется только при добавлении нового приложения."
                   Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,15"/>
        
        <!-- КНОПКИ -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="✅ Да, помогать" Width="130" Height="35"
                    Background="#4CAF50" Foreground="White" Cursor="Hand"
                    BorderThickness="0" Click="Accept_Click" Margin="0,0,15,0"/>
            <Button Content="❌ Нет, не хочу" Width="130" Height="35"
                    Background="#555" Foreground="White" Cursor="Hand"
                    BorderThickness="0" Click="Decline_Click"/>
        </StackPanel>
    </Grid>
</Window>