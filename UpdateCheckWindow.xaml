<Window x:Class="Ven4Tools.UpdateCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проверка обновлений" Height="400" Width="550"
        WindowStartupLocation="CenterOwner" Background="#2d2d2d" Foreground="White"
        ResizeMode="NoResize" WindowStyle="ToolWindow">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock x:Name="txtStatus" Text="🔍 Проверка обновлений..." 
                       Foreground="#FFA500" FontSize="16" FontWeight="Bold" 
                       HorizontalAlignment="Center"/>
            <ProgressBar x:Name="progressBar" Height="15" IsIndeterminate="True" 
                         Background="#444" Foreground="#ADD8E6" Margin="0,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" x:Name="panelResult" Visibility="Collapsed">
            <TextBlock x:Name="txtResultTitle" FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock x:Name="txtVersionInfo" FontSize="14" 
                       HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <ScrollViewer x:Name="scrollChangelog" MaxHeight="180" Margin="0,0,0,15"
                          Visibility="Collapsed" Background="#1e1e1e" BorderBrush="#444"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="txtChangelog" TextWrapping="Wrap" 
                           Foreground="#00FF00" FontFamily="Consolas" FontSize="12" 
                           Padding="10" Margin="5"/>
            </ScrollViewer>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnUpdate" Content="📥 Скачать обновление" Width="160" 
                    Background="#0078D7" Foreground="White" 
                    Click="BtnUpdate_Click" Margin="0,0,10,0" Visibility="Collapsed"/>
            <Button x:Name="btnClose" Content="Закрыть" Width="100" 
                    Background="#666666" Foreground="White" 
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>