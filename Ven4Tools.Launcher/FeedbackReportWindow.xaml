<Window x:Class="Ven4Tools.Launcher.FeedbackReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ven4Tools — Отзыв о pre-release" Height="500" Width="620"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#0d1117">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#161b22" Padding="24,16"
                BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💬" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtTitle" FontSize="15" FontWeight="SemiBold"
                               Foreground="#e6edf3"/>
                    <TextBlock Text="Отзыв будет отправлен как GitHub Issue"
                               FontSize="11" Foreground="#8b949e" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Details -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,8">

                <!-- Meta -->
                <Border Background="#161b22" BorderBrush="#30363d" BorderThickness="1"
                        CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Версия:" Foreground="#8b949e" Width="90" FontSize="12"/>
                                <TextBlock x:Name="txtVersion" Foreground="#FF9800" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Оценка:" Foreground="#8b949e" Width="90" FontSize="12"/>
                                <TextBlock x:Name="txtRating" Foreground="#FFC107" FontSize="14"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Сессия:" Foreground="#8b949e" Width="90" FontSize="12"/>
                                <TextBlock x:Name="txtSession" Foreground="#58a6ff" FontSize="12"
                                           FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="Машина:" Foreground="#8b949e" Width="90" FontSize="12"/>
                                <TextBlock x:Name="txtMachine" Foreground="#e6edf3" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Feedback text -->
                <TextBlock Text="Текст отзыва" Foreground="#8b949e" FontSize="11"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border Background="#161b22" BorderBrush="#30363d" BorderThickness="1"
                        CornerRadius="8" Padding="14,10">
                    <TextBlock x:Name="txtFeedbackText" Foreground="#e6edf3" FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#161b22" Padding="24,14"
                BorderBrush="#30363d" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatus" Grid.Column="0"
                           Foreground="#8b949e" FontSize="12" VerticalAlignment="Center"/>
                <Button x:Name="btnSkip" Grid.Column="1"
                        Content="Пропустить" Height="36" Padding="20,0"
                        Background="Transparent" Foreground="#8b949e"
                        BorderBrush="#30363d" BorderThickness="1"
                        Click="BtnSkip_Click"/>
                <Button x:Name="btnSend" Grid.Column="3"
                        Content="💬 Отправить на GitHub"
                        Height="36" Padding="20,0"
                        Background="#1f6feb" Foreground="White"
                        FontWeight="SemiBold" BorderThickness="0"
                        Click="BtnSend_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
