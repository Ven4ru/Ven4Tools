<Window x:Class="Ven4Tools.Launcher.InstallReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ven4Tools — Ошибки установки" Height="520" Width="720"
        MinHeight="400" MinWidth="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#0d1117">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#161b22" Padding="24,18"
                BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📦" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtTitle" FontSize="16" FontWeight="SemiBold"
                               Foreground="#e6edf3"/>
                    <TextBlock Text="Информация поможет улучшить совместимость каталога"
                               FontSize="12" Foreground="#8b949e" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- List of failures -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0">
            <StackPanel x:Name="pnlFailures" Margin="24,16,24,8"/>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#161b22" Padding="24,14"
                BorderBrush="#30363d" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatus" Grid.Column="0"
                           Foreground="#8b949e" FontSize="12" VerticalAlignment="Center"/>
                <Button x:Name="btnSkip" Grid.Column="1"
                        Content="Пропустить" Height="36" Padding="20,0"
                        Background="Transparent" Foreground="#8b949e"
                        BorderBrush="#30363d" BorderThickness="1"
                        Click="BtnSkip_Click"/>
                <Button x:Name="btnSend" Grid.Column="3"
                        Content="📋 Отправить отчёт на GitHub"
                        Height="36" Padding="20,0"
                        Background="#1f6feb" Foreground="White"
                        FontWeight="SemiBold" BorderThickness="0"
                        Click="BtnSend_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
