<Window x:Class="Ven4Tools.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ven4Tools Launcher" 
        Height="550" 
        Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D30"
        MinHeight="450"
        MinWidth="600">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Ven4Tools Launcher" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Foreground="#4CAF50" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <!-- Статус -->
        <Border Grid.Row="1" 
                Background="#1E1E1E" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Name="StatusText" 
                           Text="Проверка..." 
                           Foreground="#FFD966" 
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
                <ProgressBar Name="ProgressBar" 
                             Height="4" 
                             Margin="0,10,0,0"
                             IsIndeterminate="True"
                             Foreground="#4CAF50" 
                             Background="#3F3F46"
                             Visibility="Collapsed"/>
            </StackPanel>
        </Border>
        
        <!-- Лог операций (с прокруткой) -->
        <Border Grid.Row="2" 
                Background="#252526" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="📋 Лог операций" 
                           Foreground="#CCC" 
                           FontSize="12"
                           Margin="0,0,0,8"/>
                
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBox Name="LogTextBox" 
                             Background="Transparent" 
                             Foreground="#CCC" 
                             BorderThickness="0" 
                             IsReadOnly="True" 
                             FontFamily="Consolas" 
                             FontSize="10" 
                             TextWrapping="Wrap"
                             Height="Auto"/>
                </ScrollViewer>
            </Grid>
        </Border>
        
 <StackPanel Grid.Row="3" Orientation="Vertical" HorizontalAlignment="Center">
    <!-- Первая строка: основные кнопки -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
        <Button Name="BtnInstall" 
                Content="📥 Установить" 
                Width="110" 
                Height="40"
                Margin="0,0,10,0"
                Background="#4CAF50" 
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                FontSize="12"
                Click="BtnInstall_Click"/>
        <Button Name="BtnUpdate" 
                Content="🔄 Обновить" 
                Width="110" 
                Height="40"
                Margin="0,0,10,0"
                Background="#2196F3" 
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                FontSize="12"
                Click="BtnUpdate_Click"/>
        <Button Name="BtnLaunch" 
                Content="🚀 Запустить" 
                Width="110" 
                Height="40"
                Margin="0,0,10,0"
                Background="#FF9800" 
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                FontSize="12"
                Click="BtnLaunch_Click"/>
        <Button Name="CloseButton" 
                Content="❌ Закрыть" 
                Width="110" 
                Height="40"
                Background="#555" 
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                FontSize="12"
                Click="CloseButton_Click"/>
    </StackPanel>
    
    <!-- Вторая строка: дополнительные кнопки -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <Button Name="BtnRefresh" 
                Content="🔄 Обновить статус" 
                Width="120" 
                Height="35"
                Background="#9C27B0" 
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                FontSize="11"
                Click="BtnRefresh_Click"/>
    </StackPanel>
</StackPanel>
    </Grid>
</Window>