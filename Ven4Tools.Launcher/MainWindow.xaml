<Window x:Class="Ven4Tools.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ven4Tools Launcher" Height="600" Width="700"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#2D2D2D" Foreground="White"
        Closing="Window_Closing">
    
    <Window.Resources>
        <SolidColorBrush x:Key="AccentColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3D3D3D"/>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Левая панель с кнопками -->
        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Background="#252526" CornerRadius="8" Margin="0,0,10,0">
            <StackPanel Margin="10">
                <Button x:Name="btnSelectFolder" Content="📁 Выбрать папку" 
                        Height="40" Margin="0,5" Click="BtnSelectFolder_Click"/>
                <Button x:Name="btnCheckUpdates" Content="🔍 Проверить обновления" 
                        Height="40" Margin="0,5" Click="BtnCheckUpdates_Click"/>
                <Button x:Name="btnInstallUpdate" Content="📥 Установить обновление" 
                        Height="40" Margin="0,5" IsEnabled="False" Click="BtnInstallUpdate_Click"/>
                <Button x:Name="btnLaunchApp" Content="🚀 Запустить Ven4Tools" 
                        Height="40" Margin="0,5" 
                        Click="BtnLaunchApp_Click"/>
                <Button x:Name="btnExit" Content="❌ Выход" 
                        Height="40" Margin="0,5" Click="BtnExit_Click"/>
            </StackPanel>
        </Border>
        
        <!-- Правая панель -->
        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
            <GroupBox Header="📁 Папка установки">
                <TextBlock x:Name="txtInstallPath" Text="Не выбрана" 
                           Foreground="{DynamicResource TextSecondary}" 
                           TextWrapping="Wrap" Margin="5"/>
            </GroupBox>
        </StackPanel>
        
        <!-- Прогресс загрузки -->
        <Border Grid.Row="1" Grid.Column="1" Background="#252526" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="📥 Загрузка клиента" FontWeight="Bold" 
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,5"/>
                <ProgressBar x:Name="progressDownload" Height="20" Minimum="0" Maximum="100" Value="0"
                             Foreground="{DynamicResource AccentColor}" Background="{DynamicResource BorderBrush}"/>
                <TextBlock x:Name="txtDownloadStatus" Text="Готов" 
                           Foreground="{DynamicResource TextSecondary}" FontSize="11" 
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Лог -->
        <Border Grid.Row="2" Grid.Column="1" Background="#252526" CornerRadius="8" Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="📋 Лог операций" FontWeight="Bold" 
                           Foreground="{DynamicResource TextPrimary}" Margin="5,0,0,5"/>
                
                <TextBox x:Name="txtLog" Grid.Row="1"
                         Background="#1E1E1E" Foreground="#00FF00"
                         FontFamily="Consolas" FontSize="10"
                         IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,5,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>



