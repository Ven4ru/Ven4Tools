<Window x:Class="Ven4Tools.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ven4Tools Launcher" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#2D2D2D" Foreground="White"
        Closing="Window_Closing">
    
    <Window.Resources>
        <SolidColorBrush x:Key="AccentColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3D3D3D"/>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- ========== ЛЕВАЯ ПАНЕЛЬ ========== -->
        <Border Grid.Column="0" Background="#252526">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Верхняя часть: кнопки -->
                <StackPanel Grid.Row="0" Margin="10">
                    <Button x:Name="btnSelectFolder" Content="📁 Выбрать папку" 
                            Height="40" Margin="0,5" Click="BtnSelectFolder_Click"/>
                    <Button x:Name="btnCheckUpdates" Content="🔍 Проверить обновления" 
                            Height="40" Margin="0,5" Click="BtnCheckUpdates_Click"/>
                    <Button x:Name="btnInstallUpdate" Content="📥 Установить обновление" 
                            Height="40" Margin="0,5" IsEnabled="False" Click="BtnInstallUpdate_Click"/>
                    <Button x:Name="btnLaunchApp" Content="📥 Загрузить Ven4Tools" 
                            Height="40" Margin="0,5" FontWeight="Bold"
                            Background="{DynamicResource AccentColor}"
                            Click="BtnLaunchApp_Click"/>
                            <Button x:Name="btnCheckComponents" Content="🔧 Проверить компоненты" 
        Height="40" Margin="0,5" Click="BtnCheckComponents_Click"/>
                    <Button x:Name="btnExit" Content="❌ Выход" 
                            Height="40" Margin="0,5" Click="BtnExit_Click"/>
                </StackPanel>
                
                <!-- Нижняя часть: выбор версии (только выбор) -->
                <Border Grid.Row="2" Margin="10" Background="#1E1E1E" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="📦 Выбор версии" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                        
                        <ComboBox x:Name="cmbVersions" Height="30" Margin="0,0,0,5" 
                                  DisplayMemberPath="Version" 
                                  SelectionChanged="CmbVersions_SelectionChanged"/>
                        
                        <TextBlock x:Name="txtVersionInfo" Text="Выберите версию" 
                                   Foreground="{DynamicResource TextSecondary}" 
                                   FontSize="10" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- ========== ПРАВАЯ ПАНЕЛЬ (раздвижная) ========== -->
        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="colMain" Width="*"/>
                <ColumnDefinition x:Name="colDetails" Width="0"/>
            </Grid.ColumnDefinitions>
            
            <!-- Основная правая панель -->
            <StackPanel Grid.Column="0" Margin="10">
                <GroupBox Header="📁 Папка установки">
                    <TextBlock x:Name="txtInstallPath" Text="Не выбрана" 
                               Foreground="{DynamicResource TextSecondary}" 
                               TextWrapping="Wrap" Margin="5"/>
                </GroupBox>
                
                <GroupBox Header="📊 Прогресс" Margin="0,10,0,0">
                    <StackPanel>
                        <ProgressBar x:Name="progressDownload" Height="20" Minimum="0" Maximum="100" Value="0"
                                     Foreground="{DynamicResource AccentColor}" Background="{DynamicResource BorderBrush}"/>
                        <TextBlock x:Name="txtDownloadStatus" Text="Готов" 
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11" 
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </GroupBox>
                
                <GroupBox Header="📋 Лог операций" Margin="0,10,0,0" Height="200">
                    <TextBox x:Name="txtLog"
                             Background="#1E1E1E" Foreground="#00FF00"
                             FontFamily="Consolas" FontSize="10"
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,5,0,0"/>
                </GroupBox>
            </StackPanel>
            
            <!-- Раздвижная панель "Что нового" -->
            <Border Grid.Column="1" Background="#1E1E1E" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Stretch">
                        <TextBlock Text="📝 Что нового" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        <Button x:Name="btnCloseDetails" Content="✕" Width="30" Height="30" 
                                HorizontalAlignment="Right" Margin="10,0,0,0"
                                Click="BtnCloseDetails_Click"
                                Background="Transparent" Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
                        <TextBlock x:Name="txtReleaseNotes" 
                                   Foreground="{DynamicResource TextSecondary}" 
                                   TextWrapping="Wrap" FontSize="11"/>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <!-- Кнопка-раздвигатель -->
            <Button x:Name="btnToggleDetails" Content="▶" Width="24" Height="48" 
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    Background="{DynamicResource AccentColor}" Foreground="White"
                    Click="BtnToggleDetails_Click"/>
        </Grid>
    </Grid>
</Window>