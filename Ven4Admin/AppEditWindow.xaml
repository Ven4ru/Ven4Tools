<Window x:Class="Ven4Admin.AppEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование приложения"
        Width="500" Height="535"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E" Foreground="#E0E0E0"
        ResizeMode="NoResize">
    <DockPanel Margin="16">

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnOk"     Content="✅ Сохранить" Width="120" Height="32" Margin="0,0,8,0"/>
            <Button x:Name="btnCancel" Content="Отмена"       Width="90"  Height="32"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="125"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Название *:"    VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox   x:Name="txtName" Grid.Row="0" Grid.Column="1" Height="26" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Text="Категория:"     VerticalAlignment="Center" Margin="0,0,0,8"/>
                <ComboBox  x:Name="cmbCategory" Grid.Row="1" Grid.Column="1" Height="26" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="2" Text="WinGet ID:"     VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox   x:Name="txtWingetId" Grid.Row="2" Grid.Column="1" Height="26" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="3" Text="URL скачивания:" VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox   x:Name="txtUrl" Grid.Row="3" Grid.Column="1" Height="26" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="4" Text="Версия:"        VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox   x:Name="txtVersion" Grid.Row="4" Grid.Column="1" Height="26" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="5" Text="Размер:"        VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox   x:Name="txtSize" Grid.Row="5" Grid.Column="1" Height="26" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="6" Text="Icon URL:"      VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox   x:Name="txtIconUrl" Grid.Row="6" Grid.Column="1" Height="26" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="7" Text="Описание:"      VerticalAlignment="Top" Margin="0,4,0,8"/>
                <TextBox   x:Name="txtDescription" Grid.Row="7" Grid.Column="1" Height="58" Margin="0,0,0,8"
                           TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="8" Text="Флаги:"         VerticalAlignment="Center"/>
                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0">
                    <CheckBox x:Name="chkOfficial"  Content="Official"      Margin="0,0,14,0"/>
                    <CheckBox x:Name="chkRuBlocked" Content="🚫 Блок в РФ" Margin="0,0,14,0"
                              Foreground="#FF9800"/>
                    <CheckBox x:Name="chkSkipHash"  Content="Skip Hash"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
