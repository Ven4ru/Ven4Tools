<Window x:Class="Ven4Tools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ven4Tools" Height="950" Width="1300" MinHeight="750" MinWidth="1100"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackground}">
    
    <Window.Resources>
        <!-- Стиль для кнопок навигации -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="0,0,0,1" 
                                BorderBrush="{DynamicResource BorderBrush}">
                            <Grid Margin="16,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="Icon" 
                                               Text="{TemplateBinding Tag}" 
                                               Margin="0,0,12,0"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock x:Name="ContentText" 
                                               Text="{TemplateBinding Content}" 
                                               FontSize="14"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Стиль для активной кнопки навигации -->
        <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,3,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Левая панель навигации -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Логотип и название -->
                <Border Grid.Row="0" Height="80" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Image Source="/icon.ico" Width="32" Height="32" Margin="0,0,12,0"/>
                        <TextBlock Text="Ven4Tools" FontSize="20" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- Кнопки навигации -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <Button x:Name="btnCatalogTab" 
                            Style="{StaticResource NavButtonStyle}"
                            Tag="📦" 
                            Content="Каталог"
                            Click="NavigateToCatalog"/>
                    <Button x:Name="btnSystemTab" 
                            Style="{StaticResource NavButtonStyle}"
                            Tag="⚙️" 
                            Content="Система"
                            Click="NavigateToSystem"/>
                    <Button x:Name="btnOfficeTab" 
                            Style="{StaticResource NavButtonStyle}"
                            Tag="📁" 
                            Content="Office"
                            Click="NavigateToOffice"/>
                    <Button x:Name="btnActivationTab" 
                            Style="{StaticResource NavButtonStyle}"
                            Tag="🔑" 
                            Content="Активация"
                            Click="NavigateToActivation"/>
                    <Button x:Name="btnAboutTab" 
                            Style="{StaticResource NavButtonStyle}"
                            Tag="ℹ️" 
                            Content="О программе"
                            Click="NavigateToAbout"/>
                </StackPanel>
                
                <!-- Нижняя панель (тема и статус) -->
                <StackPanel Grid.Row="2" Margin="16,0,16,20">
                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,15"/>
                    
                    <!-- Переключатель темы -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🌙" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ToggleButton x:Name="btnThemeToggle" 
                                      Grid.Column="1"
                                      Height="32"
                                      Background="{DynamicResource BorderBrush}"
                                      BorderThickness="0"
                                      Checked="ToggleTheme"
                                      Unchecked="ToggleTheme">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Grid>
                                        <Border Background="{DynamicResource BorderBrush}" CornerRadius="16" Height="32">
                                            <Grid>
                                                <Rectangle x:Name="Thumb" Fill="{DynamicResource AccentColor}" 
                                                           Width="28" Height="28" RadiusX="14" RadiusY="14"
                                                           HorizontalAlignment="Left" Margin="2"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="🌙" Margin="5,0,20,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="☀️" Margin="20,0,5,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </Grid>
                    
                    <TextBlock x:Name="txtStatusBar" 
                               Text="✅ Готово" 
                               Foreground="{DynamicResource TextSecondary}" 
                               FontSize="11"
                               TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Правая область контента -->
        <Border Grid.Column="1" Background="{DynamicResource ContentBackground}">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>
