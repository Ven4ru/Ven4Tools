<Window x:Class="Ven4Tools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Ven4Tools.Views.Tabs"
        xmlns:local="clr-namespace:Ven4Tools.Views.Tabs"
        Title="Ven4Tools" Height="950" Width="1300" MinHeight="750" MinWidth="1100"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackground}"
        Closing="Window_Closing_Extended">
    
    <Window.Resources>
    <!-- Стиль для кнопок навигации -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="48"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            BorderThickness="0,0,0,1" 
                            BorderBrush="{DynamicResource BorderBrush}">
                        <Grid Margin="16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="Icon" 
                                           Text="{TemplateBinding Tag}" 
                                           Margin="0,0,12,0"
                                           FontSize="18"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                                <TextBlock x:Name="ContentText" 
                                           Text="{TemplateBinding Content}" 
                                           FontSize="14"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#505050"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <!-- Стиль для активной кнопки навигации -->
    <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,3,0"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
    </Style>
</Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Левая панель навигации -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Логотип и название -->
                <Border Grid.Row="0" Height="80" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Image Source="/icon.ico" Width="32" Height="32" Margin="0,0,12,0"/>
                        <TextBlock Text="Ven4Tools" FontSize="20" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- Кнопки навигации + маскот -->
                <DockPanel Grid.Row="1" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0">
                        <Button x:Name="btnCatalogTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="📦"
                                Content="Каталог"
                                Click="NavigateToCatalog"/>
                        <Button x:Name="btnInstalledTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="🖥️"
                                Content="Установленные"
                                Click="NavigateToInstalled"/>
                        <Button x:Name="btnSystemTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="⚙️"
                                Content="Система"
                                Click="NavigateToSystem"/>
                        <Button x:Name="btnOfficeTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="📁"
                                Content="Office"
                                Click="NavigateToOffice"/>
                        <Button x:Name="btnActivationTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="🔑"
                                Content="Активация"
                                Click="NavigateToActivation"/>
                        <Button x:Name="btnNetworkTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="🌐"
                                Content="Сеть"
                                Click="NavigateToNetwork"/>
                        <Button x:Name="btnDebloaterTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="🧹"
                                Content="Debloater"
                                Click="NavigateToDebloater"/>
                        <Button x:Name="btnDriversTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="🖱️"
                                Content="Драйверы"
                                Click="NavigateToDrivers"/>
                        <Button x:Name="btnHistoryTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="📋"
                                Content="История"
                                Click="NavigateToHistory"/>
                        <Button x:Name="btnAboutTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="ℹ️"
                                Content="О программе"
                                Click="NavigateToAbout"/>
                    </StackPanel>
                    <Image x:Name="imgMascot"
                           Visibility="Collapsed"
                           MaxHeight="190" MaxWidth="190"
                           Margin="20,0,20,16"
                           Stretch="Uniform"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </DockPanel>
                
                <!-- Нижняя панель (тема и статус) -->
                <StackPanel Grid.Row="2" Margin="16,0,16,20">

                    <!-- Блок пользователя -->
                    <Border x:Name="pnlUserLoggedIn" Visibility="Collapsed"
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="8" Padding="10,8" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="txtUserAvatar" Text="👤" FontSize="22"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtUserName" Text="" FontSize="13"
                                               FontWeight="Bold" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock x:Name="txtUserEmail" Text="" FontSize="10"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                                <Button Grid.Column="2" x:Name="btnLogout" Content="Выйти"
                                        Height="26" Padding="6,2" FontSize="11" FontWeight="Normal"
                                        Margin="4,0,0,0" Click="BtnLogout_Click"/>
                            </Grid>
                            <Button x:Name="btnProfile"
                                    Content="{DynamicResource sidebar_profile}"
                                    Height="28" FontSize="11" FontWeight="Normal"
                                    HorizontalAlignment="Stretch"
                                    Click="BtnProfile_Click"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnLogin" Content="👤  Войти в аккаунт"
                            Height="38" Margin="0,0,0,10"
                            Visibility="Visible"
                            Click="BtnLogin_Click"/>

                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,10"/>

                    <!-- Minimize to tray option -->
                    <CheckBox x:Name="chkMinimizeToTray"
                              Content="Сворачивать в трей"
                              Foreground="{DynamicResource TextSecondary}"
                              FontSize="11" Margin="0,0,0,8"
                              Click="ChkMinimizeToTray_Click"/>

                    <TextBlock x:Name="txtStatusBar"
                               Text="✅ Готово"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Правая область контента -->
        <Border Grid.Column="1" Background="{DynamicResource ContentBackground}"
                AllowDrop="True"
                DragEnter="MainArea_DragEnter"
                DragOver="MainArea_DragOver"
                DragLeave="MainArea_DragLeave"
                Drop="MainArea_Drop">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Quick pins strip -->
                <Border x:Name="pnlPins" Grid.Row="0"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,6"
                        Visibility="Collapsed">
                    <DockPanel>
                        <TextBlock Text="📌" FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{DynamicResource TextSecondary}"
                                   DockPanel.Dock="Left"/>
                        <WrapPanel x:Name="wrapPins" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Drag overlay -->
                <Border x:Name="pnlDropOverlay" Grid.Row="0" Grid.RowSpan="2"
                        Visibility="Collapsed" Panel.ZIndex="99"
                        Background="#AA1E1E2E"
                        BorderBrush="{DynamicResource AccentColor}"
                        BorderThickness="4" CornerRadius="8" Margin="8">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Отпустите для добавления установщика"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
            </Grid>
        </Border>
    </Grid>
</Window>
