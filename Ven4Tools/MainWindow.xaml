<Window x:Class="Ven4Tools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ven4Tools" Height="900" Width="1280" MinHeight="680" MinWidth="980"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackground}"
        Closing="Window_Closing_Extended" FontFamily="Segoe UI Variable Text, Segoe UI"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="13,0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="5">
                            <Grid Margin="10,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{TemplateBinding Tag}" FontFamily="Segoe Fluent Icons"
                                           FontSize="15" Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#144ADE80"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#1E4ADE80"/>
            <Setter Property="Foreground" Value="{StaticResource BrandGreen}"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock" BasedOn="{StaticResource EyebrowStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Margin" Value="12,12,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="228"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="12,0">
                <Grid.RowDefinitions><RowDefinition Height="80"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Border Width="3" Height="40" HorizontalAlignment="Left" Background="{StaticResource BrandGreen}"
                            CornerRadius="2" Effect="{StaticResource BrandAuraEffect}"/>
                    <StackPanel VerticalAlignment="Center" Margin="15,0,0,0">
                        <TextBlock FontSize="19" FontWeight="Bold"><Run Text="Ven4"/><Run Text="Tools" Foreground="{StaticResource BrandGreen}"/></TextBlock>
                        <TextBlock Text="WINDOWS TOOLKIT" Style="{StaticResource EyebrowStyle}" Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="ПРИЛОЖЕНИЯ" Style="{StaticResource SectionLabel}"/>
                        <Button x:Name="btnCatalogTab" Style="{StaticResource NavButtonStyle}" Tag="&#xE71D;" Content="Каталог" Click="NavigateToCatalog"/>
                        <Button x:Name="btnInstalledTab" Style="{StaticResource NavButtonStyle}" Tag="&#xE896;" Content="Установленные" Click="NavigateToInstalled"/>

                        <TextBlock Text="WINDOWS И СИСТЕМА" Style="{StaticResource SectionLabel}"/>
                        <Button x:Name="btnSystemTab" Style="{StaticResource NavButtonStyle}" Tag="&#xE713;" Content="Настройки" Click="NavigateToSystem"/>
                        <Grid>
                            <Button x:Name="btnWindowsUpdateTab" Style="{StaticResource NavButtonStyle}" Tag="&#xE72E;" Content="Windows Update" Click="NavigateToWindowsUpdate"/>
                            <Border x:Name="badgeWindowsUpdateCount" Background="{StaticResource StatusDanger}" CornerRadius="7"
                                    MinWidth="16" Height="15" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,8,0" Visibility="Collapsed">
                                <TextBlock x:Name="txtWindowsUpdateBadge" Text="0" FontSize="9" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0"/>
                            </Border>
                        </Grid>
                        <Button x:Name="btnOfficeTab" Style="{StaticResource NavButtonStyle}" Tag="&#xE8A5;" Content="Office" Click="NavigateToOffice"/>
                        <Button x:Name="btnActivationTab" Style="{StaticResource NavButtonStyle}" Tag="&#xE8D7;" Content="Лицензия" Click="NavigateToActivation"/>
                        <Button x:Name="btnDebloaterTab" Style="{StaticResource NavButtonStyle}" Tag="&#xE74D;" Content="Очистка" Click="NavigateToDebloater"/>

                        <TextBlock Text="СЕРВИС" Style="{StaticResource SectionLabel}"/>
                        <Button x:Name="btnNetworkTab" Style="{StaticResource NavButtonStyle}" Tag="&#xE968;" Content="Сеть" Click="NavigateToNetwork"/>
                        <Button x:Name="btnHistoryTab" Style="{StaticResource NavButtonStyle}" Tag="&#xE81C;" Content="История" Click="NavigateToHistory"/>
                        <Button x:Name="btnAboutTab" Style="{StaticResource NavButtonStyle}" Tag="&#xE946;" Content="О программе" Click="NavigateToAbout"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,8,0,12">
                    <Image x:Name="imgMascot" Visibility="Collapsed" MaxHeight="110" MaxWidth="150" Margin="10,0,10,8" Stretch="Uniform"/>
                    <Border Style="{StaticResource PillStatusStyle}" Margin="0,0,0,6">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource StatusSuccess}" Margin="0,0,7,0"/>
                                <TextBlock Text="Интернет доступен" FontSize="10" Foreground="{StaticResource StatusSuccess}"/>
                            </StackPanel>
                            <TextBlock Text="3.6.1" HorizontalAlignment="Right" FontFamily="Cascadia Mono, Consolas" FontSize="9" Foreground="{DynamicResource TextSecondary}"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{DynamicResource ContentBackground}" AllowDrop="True"
              DragEnter="MainArea_DragEnter" DragOver="MainArea_DragOver" DragLeave="MainArea_DragLeave" Drop="MainArea_Drop">
            <Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#B80D1018" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,0">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Рабочее пространство" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Управление приложениями и Windows" FontSize="10" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Style="{StaticResource PillStatusStyle}" Margin="0,0,8,0">
                            <TextBlock Text="Нет активных задач" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
                        </Border>
                        <Button Content="&#xE713;" Style="{StaticResource IconButtonStyle}" ToolTip="Настройки"
                                Click="NavigateToSystem"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="pnlPins" Grid.Row="1" Background="{DynamicResource SidebarBackground}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="14,7" Visibility="Collapsed">
                <DockPanel>
                    <TextBlock Text="&#xE840;" FontFamily="Segoe Fluent Icons" Margin="0,0,8,0" Foreground="{StaticResource BrandGreen}"/>
                    <WrapPanel x:Name="wrapPins"/>
                </DockPanel>
            </Border>

            <ContentControl x:Name="MainFrame" Grid.Row="2" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>

            <Expander Grid.Row="3" Header="Центр активности" IsExpanded="False" Margin="16,8,16,12">
                <Border Height="150" Margin="0,7,0,0" Background="{StaticResource SurfaceCard}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Button x:Name="btnClearGlobalLog" Content="&#xE74D;" Style="{StaticResource IconButtonStyle}"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,5,0"
                                Background="Transparent" Panel.ZIndex="2" ToolTip="Очистить журнал" Click="BtnClearGlobalLog_Click"/>
                        <ListBox x:Name="lstGlobalLog" Margin="6" Background="Transparent" BorderThickness="0"
                                 SelectionMode="Extended" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.IsVirtualizing="True" HorizontalContentAlignment="Stretch">
                            <ListBox.ContextMenu>
                                <ContextMenu><MenuItem Header="Копировать" Click="CopyGlobalLog_Click"/><MenuItem Header="Очистить" Click="BtnClearGlobalLog_Click"/></ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2,36,2">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62"/><ColumnDefinition Width="22"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Time}" FontFamily="Cascadia Mono, Consolas" FontSize="9" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Icon}" FontSize="10" Foreground="{Binding IconBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Message}" FontSize="10" TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Expander>

            <Border x:Name="pnlDropOverlay" Grid.Row="0" Grid.RowSpan="4" Visibility="Collapsed" Panel.ZIndex="99"
                    Background="#E60A0A14" BorderBrush="{StaticResource BrandGreen}" BorderThickness="2" CornerRadius="8" Margin="12">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons" FontSize="44" Foreground="{StaticResource BrandGreen}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Добавить локальный установщик" FontSize="19" FontWeight="SemiBold" Margin="0,14,0,0"/>
                    <TextBlock Text="Отпустите файл, чтобы продолжить" Foreground="{DynamicResource TextSecondary}" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
