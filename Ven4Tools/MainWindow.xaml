<Window x:Class="Ven4Tools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Ven4Tools.Views.Tabs"
        xmlns:local="clr-namespace:Ven4Tools.Views.Tabs"
        Title="Ven4Tools" Height="900" Width="1280" MinHeight="620" MinWidth="960"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackground}"
        Closing="Window_Closing_Extended">
    
    <Window.Resources>
    <!-- Стиль для кнопок навигации -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="48"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            BorderThickness="0,0,0,1" 
                            BorderBrush="{DynamicResource BorderBrush}">
                        <Grid Margin="16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="Icon" 
                                           Text="{TemplateBinding Tag}" 
                                           Margin="0,0,12,0"
                                           FontSize="18"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                                <TextBlock x:Name="ContentText" 
                                           Text="{TemplateBinding Content}" 
                                           FontSize="14"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#0A3555"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <!-- Стиль для активной кнопки навигации -->
    <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,3,0"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
    </Style>
</Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Левая панель навигации -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Логотип и название -->
                <Border Grid.Row="0" Height="80" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <!-- Акцентная полоса слева -->
                        <Border Width="4" HorizontalAlignment="Left" Background="{DynamicResource AccentColor}" CornerRadius="0,2,2,0"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,16,0">
                            <Image Source="/icon.ico" Width="32" Height="32" Margin="0,0,12,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Ven4Tools" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Setup Assistant" FontSize="10"
                                           Foreground="{DynamicResource AccentColor}"
                                           Opacity="0.85"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Кнопки навигации + лог + маскот -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,20,0,0">
                        <Button x:Name="btnCatalogTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="📦"
                                Content="Каталог"
                                Click="NavigateToCatalog"/>
                        <Button x:Name="btnInstalledTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="🖥️"
                                Content="Установленные"
                                Click="NavigateToInstalled"/>
                        <Button x:Name="btnSystemTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="⚙️"
                                Content="Система"
                                Click="NavigateToSystem"/>
                        <Grid>
                            <Button x:Name="btnWindowsUpdateTab"
                                    Style="{StaticResource NavButtonStyle}"
                                    Tag="🛡️"
                                    Content="Windows Update"
                                    Click="NavigateToWindowsUpdate"/>
                            <Border x:Name="badgeWindowsUpdateCount"
                                    Background="#E74C3C" CornerRadius="8"
                                    Width="18" Height="16"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,4,8,0" Visibility="Collapsed">
                                <TextBlock x:Name="txtWindowsUpdateBadge" Text="0"
                                           FontSize="10" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <Button x:Name="btnOfficeTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="📁"
                                Content="Office"
                                Click="NavigateToOffice"/>
                        <Button x:Name="btnActivationTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="🔑"
                                Content="Активация"
                                Click="NavigateToActivation"/>
                        <Button x:Name="btnNetworkTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="🌐"
                                Content="Сеть"
                                Click="NavigateToNetwork"/>
                        <Button x:Name="btnDebloaterTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="🧹"
                                Content="Очистка"
                                Click="NavigateToDebloater"/>
                        <Button x:Name="btnHistoryTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="📋"
                                Content="История"
                                Click="NavigateToHistory"/>
                        <Button x:Name="btnAboutTab"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="ℹ️"
                                Content="О программе"
                                Click="NavigateToAbout"/>
                    </StackPanel>

                    <!-- Лог активности в сайдбаре -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="10,5"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,1">
                            <DockPanel>
                                <Button x:Name="btnClearGlobalLog" Content="✕"
                                        DockPanel.Dock="Right"
                                        Width="20" Height="20" Padding="0"
                                        FontSize="10"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextSecondary}"
                                        BorderThickness="0"
                                        Click="BtnClearGlobalLog_Click"/>
                                <TextBlock Text="📋 Лог"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <ListBox x:Name="lstGlobalLog" Grid.Row="1"
                                 Background="{DynamicResource SidebarBackground}"
                                 BorderThickness="0"
                                 SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="📋  Копировать" Click="CopyGlobalLog_Click"/>
                                    <MenuItem Header="🗑️  Очистить" Click="BtnClearGlobalLog_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Background="Transparent">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#1A3A5A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="2,0,0,0" BorderBrush="{Binding AccentBrush}"
                                            Padding="6,2,4,2" Margin="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Time}"
                                                       FontFamily="Consolas" FontSize="9"
                                                       Foreground="#3A8AAA" VerticalAlignment="Center"
                                                       Margin="0,0,5,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Icon}"
                                                       FontSize="11" Foreground="{Binding IconBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Message}"
                                                       FontSize="10" Foreground="{DynamicResource TextPrimary}"
                                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Image x:Name="imgMascot" Grid.Row="2"
                           Visibility="Collapsed"
                           MaxHeight="190" MaxWidth="190"
                           Margin="20,0,20,16"
                           Stretch="Uniform"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Grid>
                
            </Grid>
        </Border>
        
        <!-- Правая область контента -->
        <Border Grid.Column="1" Background="{DynamicResource ContentBackground}"
                AllowDrop="True"
                DragEnter="MainArea_DragEnter"
                DragOver="MainArea_DragOver"
                DragLeave="MainArea_DragLeave"
                Drop="MainArea_Drop">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Quick pins strip -->
                <Border x:Name="pnlPins" Grid.Row="0"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,6"
                        Visibility="Collapsed">
                    <DockPanel>
                        <TextBlock Text="📌" FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{DynamicResource TextSecondary}"
                                   DockPanel.Dock="Left"/>
                        <WrapPanel x:Name="wrapPins" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Drag overlay -->
                <Border x:Name="pnlDropOverlay" Grid.Row="0" Grid.RowSpan="2"
                        Visibility="Collapsed" Panel.ZIndex="99"
                        Background="#AA0B1D2E"
                        BorderBrush="{DynamicResource AccentColor}"
                        BorderThickness="4" CornerRadius="8" Margin="8">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Отпустите для добавления установщика"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <ContentControl x:Name="MainFrame" Grid.Row="1"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"/>

            </Grid>
        </Border>
    </Grid>
</Window>
