<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=mscorlib">

    <!-- Category Selection Window -->
    <s:String x:Key="cat_window_title">Welcome to Ven4Tools!</s:String>
    <s:String x:Key="cat_window_subtitle">Choose the catalog display mode</s:String>

    <s:String x:Key="cat_basic_icon">🚀</s:String>
    <s:String x:Key="cat_basic_title">Basic</s:String>
    <s:String x:Key="cat_basic_sub">Quick Windows Setup</s:String>
    <s:String x:Key="cat_basic_desc">Browsers, office, multimedia and system utilities — everything needed to get your PC running fast</s:String>

    <s:String x:Key="cat_ext_icon">⚙️</s:String>
    <s:String x:Key="cat_ext_title">Extended</s:String>
    <s:String x:Key="cat_ext_sub">For enthusiasts</s:String>
    <s:String x:Key="cat_ext_desc">Everything basic plus development tools, editors, graphics apps and messengers</s:String>

    <s:String x:Key="cat_full_icon">💎</s:String>
    <s:String x:Key="cat_full_title">Full</s:String>
    <s:String x:Key="cat_full_sub">Full catalog</s:String>
    <s:String x:Key="cat_full_desc">All available apps without exception, including gaming services and driver packages</s:String>

    <s:String x:Key="cat_continue">Continue</s:String>

    <!-- Profile Window -->
    <s:String x:Key="prof_title">Profile</s:String>
    <s:String x:Key="prof_tab_catalog">📦 Catalog</s:String>
    <s:String x:Key="prof_tab_ui">🎨 Interface</s:String>
    <s:String x:Key="prof_tab_install">🔧 Installation</s:String>
    <s:String x:Key="prof_tab_notif">🔔 Notifications</s:String>
    <s:String x:Key="prof_tab_privacy">🔒 Privacy</s:String>

    <!-- Catalog tab -->
    <s:String x:Key="prof_catalog_mode_label">Catalog mode:</s:String>
    <s:String x:Key="prof_catalog_mode_basic">Basic</s:String>
    <s:String x:Key="prof_catalog_mode_extended">Extended</s:String>
    <s:String x:Key="prof_catalog_mode_full">Full</s:String>
    <s:String x:Key="prof_catalog_sort_label">Default sort:</s:String>
    <s:String x:Key="prof_catalog_sort_alpha">Alphabetical</s:String>
    <s:String x:Key="prof_catalog_sort_category">By category</s:String>
    <s:String x:Key="prof_catalog_sort_popularity">By popularity</s:String>
    <s:String x:Key="prof_catalog_hide_installed">Hide already installed apps</s:String>
    <s:String x:Key="prof_catalog_free_only">Show free apps only</s:String>

    <!-- UI tab -->
    <s:String x:Key="prof_ui_theme_label">Theme:</s:String>
    <s:String x:Key="prof_ui_theme_dark">🌙 Dark</s:String>
    <s:String x:Key="prof_ui_theme_light">☀️ Light</s:String>
    <s:String x:Key="prof_ui_lang_label">Interface language:</s:String>
    <s:String x:Key="prof_ui_lang_auto">Auto-detect (system)</s:String>
    <s:String x:Key="prof_ui_lang_ru">Русский</s:String>
    <s:String x:Key="prof_ui_lang_en">English</s:String>
    <s:String x:Key="prof_ui_compact">Compact catalog mode</s:String>
    <s:String x:Key="prof_ui_descriptions">Show app descriptions in catalog</s:String>

    <!-- Install tab -->
    <s:String x:Key="prof_install_silent">Silent install (no confirmation dialogs)</s:String>
    <s:String x:Key="prof_install_auto_deps">Install dependencies automatically</s:String>
    <s:String x:Key="prof_install_folder_label">Default install folder:</s:String>
    <s:String x:Key="prof_install_folder_browse">Browse...</s:String>

    <!-- Notifications tab -->
    <s:String x:Key="prof_notif_app_updates">Notify about app updates from catalog</s:String>
    <s:String x:Key="prof_notif_new_apps">Notify about new apps in catalog</s:String>

    <!-- Privacy tab -->
    <s:String x:Key="prof_privacy_sync_favorites">Sync favorites across devices</s:String>
    <s:String x:Key="prof_privacy_history">Save installation history</s:String>
    <s:String x:Key="prof_privacy_stats">Anonymous usage statistics</s:String>
    <s:String x:Key="prof_privacy_stats_hint">Helps us improve the app selection</s:String>
    <s:String x:Key="prof_privacy_device_label">Data on this device</s:String>
    <s:String x:Key="prof_privacy_no_local_storage">Don't save session on this device</s:String>
    <s:String x:Key="prof_privacy_no_local_storage_hint">You will need to sign in every time you launch the app</s:String>
    <s:String x:Key="prof_privacy_delete_local">🗑 Delete data from this computer</s:String>
    <s:String x:Key="prof_privacy_delete_title">Delete local data</s:String>
    <s:String x:Key="prof_privacy_delete_confirm">Delete local data? This will clear: session, app list and catalog cache. Your account data on the server will remain.</s:String>
    <s:String x:Key="prof_privacy_delete_done">Data deleted. You have been signed out.</s:String>

    <!-- Buttons -->
    <s:String x:Key="prof_save">Save</s:String>
    <s:String x:Key="prof_cancel">Cancel</s:String>
    <s:String x:Key="prof_reset">Reset settings</s:String>
    <s:String x:Key="prof_lang_restart">Language changed. Restart the app to fully apply.</s:String>

    <!-- Sidebar -->
    <s:String x:Key="sidebar_profile">⚙ Profile</s:String>

</ResourceDictionary>
