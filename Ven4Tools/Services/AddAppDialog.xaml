<Window x:Class="Ven4Tools.Services.AddAppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить своё приложение" Height="580" Width="550"
        WindowStartupLocation="CenterOwner" Background="#2d2d2d" Foreground="White"
        ResizeMode="NoResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#2d2d2d">
        <StackPanel Margin="15">

            <!-- Выбор режима -->
            <TextBlock Text="Источник установки:" FontWeight="Bold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <RadioButton x:Name="rbWinget" Content="🔍 Winget" IsChecked="True"
                             GroupName="Mode" Foreground="White" FontSize="13"
                             Margin="0,0,24,0" Checked="RbMode_Checked"/>
                <RadioButton x:Name="rbUrl" Content="🔗 Прямая ссылка"
                             GroupName="Mode" Foreground="White" FontSize="13"
                             Checked="RbMode_Checked"/>
            </StackPanel>

            <!-- ── Winget ── -->
            <StackPanel x:Name="panelWinget">
                <TextBlock Text="Поиск по названию:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSearchQuery" Padding="5"
                             Background="#3d3d3d" Foreground="White"
                             KeyDown="TxtSearchQuery_KeyDown"/>
                    <Button x:Name="btnSearchWinget" Grid.Column="1" Content="🔍 Найти"
                            Background="#0078D7" Foreground="White" Height="30" Width="85"
                            Margin="8,0,0,0" Click="BtnSearchWinget_Click"/>
                </Grid>

                <ProgressBar x:Name="pbSearchProgress" Height="3" IsIndeterminate="True"
                             Visibility="Collapsed" Background="#444" Foreground="#ADD8E6"
                             Margin="0,0,0,8"/>

                <StackPanel x:Name="panelSearchResults" Visibility="Collapsed" Margin="0,0,0,12">
                    <TextBlock Text="Результаты поиска:" Foreground="#888" FontSize="12" Margin="0,0,0,4"/>
                    <ListBox x:Name="lstSearchResults" Background="#1e1e1e" BorderBrush="#333"
                             Foreground="White" Height="110"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             DisplayMemberPath="DisplayName"
                             SelectionChanged="LstSearchResults_SelectionChanged"/>
                    <TextBlock x:Name="txtNoResults" Text="Ничего не найдено"
                               Foreground="#FF6347" Visibility="Collapsed" Margin="4,4,0,0"/>
                </StackPanel>

                <TextBlock Text="Winget ID:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtWingetId" Padding="5"
                             Background="#3d3d3d" Foreground="White"
                             TextChanged="TxtWingetId_TextChanged"/>
                    <Button x:Name="btnValidateId" Grid.Column="1" Content="✓ Проверить"
                            Background="#444" Foreground="White" Height="30" Width="95"
                            Margin="8,0,0,0" IsEnabled="False" Click="BtnValidateId_Click"/>
                </Grid>
                <TextBlock x:Name="txtValidateResult" FontSize="11" Margin="0,4,0,12"
                           Foreground="#888" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- ── URL ── -->
            <StackPanel x:Name="panelUrl" Visibility="Collapsed">
                <TextBlock Text="Ссылка для скачивания (.exe / .msi, только https://):" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUrl" Margin="0,0,0,12" Padding="5"
                         Background="#3d3d3d" Foreground="White"/>
                <TextBlock Text="SHA256 файла (опционально — без него установка по ссылке будет недоступна):" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtSha256" Margin="0,0,0,4" Padding="5"
                         Background="#3d3d3d" Foreground="White" FontFamily="Consolas"/>
                <TextBlock Text="64 hex-символа. Посчитать: certutil -hashfile файл SHA256"
                           FontSize="11" Foreground="#888" Margin="0,0,0,20"/>
            </StackPanel>

            <!-- Название (всегда) -->
            <TextBlock Text="Название программы:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtName" Margin="0,0,0,20" Padding="5"
                     Background="#3d3d3d" Foreground="White"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnOk" Content="Добавить" Width="100" Height="35"
                        Background="#0078D7" Foreground="White" FontWeight="Bold"
                        Click="BtnOk_Click" Margin="0,0,10,0"/>
                <Button Content="Отмена" Width="100" Height="35"
                        Background="#666" Foreground="White" Click="BtnCancel_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
