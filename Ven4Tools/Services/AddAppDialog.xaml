<Window x:Class="Ven4Tools.Services.AddAppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить своё приложение" Height="550" Width="550"
        WindowStartupLocation="CenterOwner" Background="#2d2d2d" Foreground="White"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="#2d2d2d">
        <StackPanel Margin="15">
            <!-- Название программы -->
            <TextBlock Text="Название программы:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtName" Margin="0,0,0,15" Padding="5" 
                     Background="#3d3d3d" Foreground="White"/>

            <!-- Кнопка поиска в winget -->
            <Button x:Name="btnSearchWinget" Content="🔍 Поиск в winget" 
                    Background="#0078D7" Foreground="White" Height="35" Margin="0,0,0,10"
                    Click="BtnSearchWinget_Click"/>
            
            <!-- Индикатор загрузки -->
            <ProgressBar x:Name="pbSearchProgress" Height="3" IsIndeterminate="True" 
                         Visibility="Collapsed" Background="#444" Foreground="#ADD8E6" Margin="0,0,0,10"/>

            <!-- Панель результатов поиска -->
            <StackPanel x:Name="panelSearchResults" Margin="0,0,0,15" Visibility="Collapsed">
                <TextBlock Text="Результаты поиска в winget:" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                <ListBox x:Name="lstSearchResults" Background="#1e1e1e" BorderBrush="#333" 
                         Foreground="White" Height="120" 
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         DisplayMemberPath="DisplayName"
                         SelectionMode="Single"/>
                <TextBlock x:Name="txtNoResults" Text="Ничего не найдено" 
                           Foreground="#FF6347" Visibility="Collapsed" Margin="5"/>
            </StackPanel>

            <!-- ID для Winget (заполняется автоматически при выборе из списка) -->
            <TextBlock Text="ID для Winget (опционально):" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtWingetId" Margin="0,0,0,15" Padding="5" 
                     Background="#3d3d3d" Foreground="White"/>

            <!-- Прямая ссылка -->
            <TextBlock Text="Прямая ссылка для скачивания (опционально):" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtUrl" Margin="0,0,0,20" Padding="5" 
                     Background="#3d3d3d" Foreground="White"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnOk" Content="Добавить" Width="100" Height="35" 
                        Background="#0078D7" Foreground="White" Click="BtnOk_Click" Margin="0,0,10,0"/>
                <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" 
                        Background="#666666" Foreground="White" Click="BtnCancel_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>