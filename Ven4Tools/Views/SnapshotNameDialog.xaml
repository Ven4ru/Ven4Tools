<Window x:Class="Ven4Tools.Views.SnapshotNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый снапшот" Height="185" Width="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📸 Новый снапшот конфигурации"
                   FontSize="15" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1" Text="Название"
                   FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"/>
        <TextBox x:Name="txtName" Grid.Row="2"
                 Height="30" Margin="0,0,0,10"
                 Background="{DynamicResource CardBackground}"
                 Foreground="{DynamicResource TextPrimary}"
                 VerticalContentAlignment="Center" Padding="8,0"
                 MaxLength="40"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="txtSummary" FontSize="11" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,12,0"/>
            <Button Content="Отмена" Width="70" Height="30" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Сохранить" Width="80" Height="30"
                    Background="{DynamicResource AccentColor}" Foreground="White"
                    BorderThickness="0" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
