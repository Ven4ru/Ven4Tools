<UserControl x:Class="Ven4Tools.Views.Tabs.OfficeTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Установка Microsoft Office" FontSize="24" FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>
            
            <TextBlock Text="Загрузка официального установщика Office с серверов Microsoft" 
                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20" TextWrapping="Wrap"/>
            
            <GroupBox Header="📦 Выбор версии" Margin="0,0,0,15">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Версия Office:" FontWeight="Bold" Margin="0,0,0,5" 
                               Foreground="{DynamicResource TextPrimary}"/>
                    <ComboBox x:Name="cmbOfficeVersion" Grid.Row="1" Height="35" Margin="0,0,0,15"
                              Background="White" Foreground="Black"/>
                    
                    <TextBlock Text="Язык интерфейса:" Grid.Row="2" FontWeight="Bold" Margin="0,0,0,5"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <ComboBox x:Name="cmbOfficeLanguage" Grid.Row="3" Height="35" Margin="0,0,0,15"
                              Background="White" Foreground="Black"/>
                    
                    <CheckBox x:Name="chkSaveInstaller" Grid.Row="4" Content="Сохранить установщик после установки"
                              Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10" IsChecked="False"/>
                </Grid>
            </GroupBox>
            
            <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                <Button x:Name="btnInstallOffice" Content="📥 Скачать и установить"
                        Height="45" Width="250"
                        Background="#0078D4" Foreground="White" FontWeight="Bold" FontSize="14"
                        Margin="0,0,10,0"/>
                <Button x:Name="btnCancelOffice" Content="⏹️ Отмена"
                        Height="45" Width="120"
                        Background="#555" Foreground="White" FontWeight="Bold" FontSize="13"
                        IsEnabled="False"/>
            </StackPanel>

            <!-- Панель прогресса — видна только во время загрузки / установки -->
            <Border x:Name="pnlProgress" Visibility="Collapsed"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock x:Name="txtInstallPhase"
                               Text="⏳ Подготовка..."
                               FontWeight="Bold" FontSize="13"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <ProgressBar x:Name="progressOffice"
                                 Height="8" Minimum="0" Maximum="100" Value="0"
                                 Foreground="#0078D4"
                                 Background="{DynamicResource BorderBrush}"/>
                    <TextBlock x:Name="txtInstallDetail"
                               Text=""
                               FontSize="11" Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="ℹ️ Примечание: регион Windows временно переключается на US для обхода блокировок и восстанавливается только после завершения установки."
                       Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/>

            <TextBlock Text="⚠️ Требуется подключение к интернету для скачивания установщика."
                       Foreground="#FFA500" FontSize="11" Margin="0,5,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
