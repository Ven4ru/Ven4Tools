<UserControl x:Class="Ven4Tools.Views.Tabs.CatalogTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: список приложений -->
        <GroupBox Header="Каталог приложений" Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
            <DockPanel>
                <!-- Поиск -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSearch" Height="28"
                             Background="{DynamicResource CardBackground}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalContentAlignment="Center" Padding="5,0"
                             Tag="Поиск по названию или категории"/>
                    <Button x:Name="btnClearSearch" Grid.Column="1" Content="&#xE711;" FontFamily="Segoe Fluent Icons"
                            Width="28" Height="28" Margin="4,0,0,0"
                            Visibility="Collapsed"/>
                    <Button x:Name="btnFavoritesOnly" Grid.Column="2" Content="&#xE734;" FontFamily="Segoe Fluent Icons"
                            Width="28" Height="28" Margin="4,0,0,0"
                            FontSize="16" ToolTip="Только избранные"
                            Background="Transparent" BorderThickness="1"/>
                </Grid>

                <!-- Загрузка -->
                <TextBlock x:Name="txtLoadingStatus" DockPanel.Dock="Top"
                           Text="⏳ Загрузка каталога..."
                           Foreground="{DynamicResource AccentColor}"
                           FontSize="11" Margin="0,0,0,5"
                           Visibility="Collapsed"/>

                <!-- Заглушка при ошибке загрузки каталога -->
                <Border x:Name="pnlCatalogError" DockPanel.Dock="Top"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="#C0392B"
                        BorderThickness="1" CornerRadius="3"
                        Margin="0,0,0,6" Visibility="Collapsed">
                    <StackPanel Margin="8,6">
                        <TextBlock Text="❌ Каталог недоступен"
                                   Foreground="#C0392B"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBlock x:Name="txtCatalogErrorDetail"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11" TextWrapping="Wrap"/>
                        <Button x:Name="btnRetryLoadCatalog"
                                Content="🔄 Повторить загрузку"
                                Click="BtnRetryLoadCatalog_Click"
                                Margin="0,5,0,0" HorizontalAlignment="Left"
                                Padding="8,3" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Winget подсказки -->
                <Border x:Name="pnlWingetSuggestions" DockPanel.Dock="Top"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource AccentColor}"
                        BorderThickness="1" CornerRadius="3"
                        Margin="0,0,0,6" Visibility="Collapsed">
                    <StackPanel Margin="8,6">
                        <TextBlock x:Name="txtSuggestionsHeader"
                                   Text="🔍 Не нашли в каталоге? Поиск по источникам:"
                                   Foreground="{DynamicResource AccentColor}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <StackPanel x:Name="pnlWingetResults"/>
                        <TextBlock x:Name="txtWingetStatus"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Expander Header="🌐 Браузеры" IsExpanded="True">
                            <StackPanel x:Name="PanelБраузеры" Margin="15,3,0,3"/>
                        </Expander>
                        <Expander Header="📁 Офис" IsExpanded="True">
                            <StackPanel x:Name="PanelОфис" Margin="15,3,0,3"/>
                        </Expander>
                        <Expander Header="🎨 Графика" IsExpanded="True">
                            <StackPanel x:Name="PanelГрафика" Margin="15,3,0,3"/>
                        </Expander>
                        <Expander Header="💻 Разработка" IsExpanded="True">
                            <StackPanel x:Name="PanelРазработка" Margin="15,3,0,3"/>
                        </Expander>
                        <Expander Header="💬 Мессенджеры" IsExpanded="True">
                            <StackPanel x:Name="PanelМессенджеры" Margin="15,3,0,3"/>
                        </Expander>
                        <Expander Header="🎵 Мультимедиа" IsExpanded="True">
                            <StackPanel x:Name="PanelМультимедиа" Margin="15,3,0,3"/>
                        </Expander>
                        <Expander Header="⚙️ Системные" IsExpanded="True">
                            <StackPanel x:Name="PanelСистемные" Margin="15,3,0,3"/>
                        </Expander>
                        <Expander Header="🎮 Игровые сервисы" IsExpanded="True">
                            <StackPanel x:Name="PanelИгровыеСервисы" Margin="15,3,0,3"/>
                        </Expander>
                        <Expander Header="🖨️ Драйверпаки" IsExpanded="True">
                            <StackPanel x:Name="PanelДрайверпаки" Margin="15,3,0,3"/>
                        </Expander>
                        <Expander Header="📎 Другое" IsExpanded="True">
                            <StackPanel x:Name="PanelДругое" Margin="15,3,0,3"/>
                        </Expander>
                        <Expander Header="👤 Пользовательские" IsExpanded="True">
                            <StackPanel x:Name="PanelПользовательские" Margin="15,3,0,3"/>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </GroupBox>

        <!-- Правая панель: управление -->
        <ScrollViewer Grid.Row="0" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <GroupBox Header="Инструменты каталога">
                    <StackPanel>
                        <Button x:Name="btnCheckUpdates" Content="Проверить обновления" Height="35" Margin="3"/>
                        <Button x:Name="btnRefreshCatalog" Content="Обновить каталог" Height="35" Margin="3"/>
                        <Button x:Name="btnRefreshAvailability" Content="Проверить доступность" Height="35" Margin="3"/>
                        <Button x:Name="btnClearAllUserApps" Content="Очистить добавленные" Height="35" Margin="3" Foreground="{StaticResource StatusDanger}"/>
                        <Separator Margin="3,4"/>
                        <Button x:Name="btnExportList" Content="Экспорт списка" Height="32" Margin="3"
                                ToolTip="Сохранить выбранные приложения в JSON" Click="BtnExportList_Click"/>
                        <Button x:Name="btnImportList" Content="Импорт списка" Height="32" Margin="3"
                                ToolTip="Загрузить список приложений из JSON" Click="BtnImportList_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- Пресеты -->
                <GroupBox Header="📋 Пресеты" Margin="0,10,0,0">
                    <StackPanel>
                        <Button x:Name="btnSavePreset"
                                Content="💾 Сохранить выбор"
                                Height="32" Margin="3"
                                IsEnabled="False"
                                Click="BtnSavePreset_Click"
                                ToolTip="Сохранить отмеченные приложения как пресет"/>

                        <ItemsControl x:Name="lstPresets" Margin="3,4,3,2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2" Padding="8,6"
                                            Background="{DynamicResource CardBackground}"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding AppCountLabel}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextSecondary}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="→"
                                                        Width="26" Height="26" Padding="0"
                                                        FontSize="13" Margin="2,0,0,0"
                                                        Tag="{Binding}"
                                                        ToolTip="Применить пресет"
                                                        Click="BtnApplyPreset_Click"/>
                                                <Button Content="✏"
                                                        Width="26" Height="26" Padding="0"
                                                        FontSize="11" Margin="2,0,0,0"
                                                        Tag="{Binding}"
                                                        ToolTip="Изменить название и описание"
                                                        Click="BtnRenamePreset_Click"/>
                                                <Button Content="↻"
                                                        Width="26" Height="26" Padding="0"
                                                        FontSize="12" Margin="2,0,0,0"
                                                        Tag="{Binding}"
                                                        ToolTip="Применить пресет и обновить состав"
                                                        Click="BtnUpdateAppsPreset_Click"/>
                                                <Button Content="✕"
                                                        Width="26" Height="26" Padding="0"
                                                        FontSize="11" Margin="2,0,0,0"
                                                        Background="Transparent"
                                                        Foreground="{DynamicResource TextSecondary}"
                                                        BorderThickness="0"
                                                        Tag="{Binding}"
                                                        ToolTip="Удалить пресет"
                                                        Click="BtnDeletePreset_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="txtPresetsEmpty"
                                   Text="Нет сохранённых пресетов"
                                   FontSize="11" Margin="6,2,6,4"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Visibility="Collapsed"/>

                    </StackPanel>
                </GroupBox>

                <GroupBox Header="💾 Диск установки" Margin="0,10,0,0">
                    <StackPanel>
                        <ComboBox x:Name="cmbAvailableDisks" Height="28"/>
                        <TextBlock x:Name="txtSpaceStatus" FontSize="10" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        <ProgressBar x:Name="installProgressBar" Height="8" Margin="0,5,0,0" Minimum="0" Maximum="100" Value="0"/>
                        <TextBlock x:Name="txtOverallStatus" Text="Готов" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="📊 Прогресс установки" Margin="0,10,0,0" Height="160">
                    <ListBox x:Name="lstAppProgress"
                             Background="{DynamicResource CardBackground}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4,3"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding AppName}"
                                               FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Status}" Grid.Column="1"
                                               FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                               Margin="6,0,0,0"/>
                                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                                 Height="4" Margin="0,3,0,0"
                                                 Value="{Binding Percentage}"
                                                 Background="{DynamicResource BorderBrush}"
                                                 Foreground="{DynamicResource AccentColor}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0" Padding="14,10"
                Background="{StaticResource SurfaceCard}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="7" Effect="{StaticResource PanelShadowEffect}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ВЫБРАННЫЕ ПРИЛОЖЕНИЯ" Style="{StaticResource EyebrowStyle}"/>
                    <TextBlock x:Name="txtSelectionBar" Text="Ничего не выбрано" FontSize="12" Margin="0,3,0,0"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
                <Button x:Name="btnCancelInstall" Grid.Column="1" Content="Отмена" Height="38" MinWidth="90"
                        Margin="0,0,8,0" IsEnabled="False" Foreground="{StaticResource StatusDanger}"/>
                <Button x:Name="btnInstall" Grid.Column="2" Content="Установить выбранные" Height="38" MinWidth="190"
                        IsEnabled="False" Background="{StaticResource BrandGreen}" Foreground="#06130D"
                        Effect="{StaticResource BrandAuraEffect}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
