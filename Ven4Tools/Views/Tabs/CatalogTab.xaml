<UserControl x:Class="Ven4Tools.Views.Tabs.CatalogTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Ven4Tools.ViewModels"
             Background="{DynamicResource ContentBackground}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <vm:CategoryNameToHeaderConverter x:Key="CategoryHeaderConverter"/>
        <vm:StringToVisibilityConverter x:Key="StringToVis"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: список приложений -->
        <GroupBox Header="Каталог приложений" Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
            <DockPanel>
                <!-- Поиск -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSearch" Height="28"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource CardBackground}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             VerticalContentAlignment="Center" Padding="5,0"
                             Tag="Поиск по названию или категории"/>
                    <Button x:Name="btnClearSearch" Grid.Column="1" Content="&#xE711;" FontFamily="Segoe Fluent Icons"
                            Width="28" Height="28" Margin="4,0,0,0"
                            Command="{Binding ClearSearchCommand}"
                            Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVis}}"/>
                    <Button x:Name="btnFavoritesOnly" Grid.Column="2" Content="&#xE734;" FontFamily="Segoe Fluent Icons"
                            Width="28" Height="28" Margin="4,0,0,0"
                            FontSize="16" ToolTip="Только избранные"
                            Command="{Binding ToggleFavoritesOnlyCommand}"
                            Foreground="{Binding FavoritesOnlyBrush}"
                            Background="Transparent" BorderThickness="1"/>
                </Grid>

                <!-- Загрузка -->
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding StatusText}"
                           Foreground="{DynamicResource AccentColor}"
                           FontSize="11" Margin="0,0,0,5"/>

                <!-- Заглушка при ошибке загрузки каталога -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="#C0392B"
                        BorderThickness="1" CornerRadius="3"
                        Margin="0,0,0,6"
                        Visibility="{Binding CatalogErrorVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="8,6">
                        <TextBlock Text="❌ Каталог недоступен"
                                   Foreground="#C0392B"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding CatalogErrorDetail}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11" TextWrapping="Wrap"/>
                        <Button x:Name="btnRetryLoadCatalog"
                                Content="🔄 Повторить загрузку"
                                Command="{Binding RetryLoadCatalogCommand}"
                                Margin="0,5,0,0" HorizontalAlignment="Left"
                                Padding="8,3" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Winget/Choco подсказки -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource AccentColor}"
                        BorderThickness="1" CornerRadius="3"
                        Margin="0,0,0,6"
                        Visibility="{Binding ShowSuggestionsPanel, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="8,6">
                        <TextBlock Text="🔍 Не нашли в каталоге? Поиск по источникам:"
                                   Foreground="{DynamicResource AccentColor}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Suggestions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SearchSuggestionViewModel}">
                                    <Button HorizontalAlignment="Left" Margin="0,1" Height="26" Padding="6,0"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            FontSize="12" ToolTip="{Binding SourceLabel}"
                                            Command="{Binding AddCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="➕  " Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Hint, StringFormat='  {0}'}" Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="txtWingetStatus" Text="{Binding SuggestionsStatus}"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                   Visibility="{Binding SuggestionsStatus, Converter={StaticResource StringToVis}}"/>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <!-- IsSharedSizeScope + SharedSizeGroup на колонках строки ниже — имя
                         каждого приложения выравнивается по самому длинному во всём списке,
                         поэтому кнопки у всех строк (во всех категориях) начинаются с одного
                         и того же места по X, как в таблице с двумя колонками. -->
                    <ItemsControl Grid.IsSharedSizeScope="True" ItemsSource="{Binding AppsView}">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <!-- DataContext контейнера — CollectionViewGroup; Name — ключ
                                                         группировки (AppRowViewModel.CategoryString). Конвертер
                                                         превращает его в готовую CategoryHeaderViewModel — так же,
                                                         как раньше ApplyCategorySourceHeaders строил заголовок
                                                         Expander'а императивно в CatalogTab.Catalog.cs. -->
                                                    <Expander IsExpanded="True" Margin="0,0,0,3"
                                                              Header="{Binding Name, Converter={StaticResource CategoryHeaderConverter}}">
                                                        <Expander.HeaderTemplate>
                                                            <DataTemplate DataType="{x:Type vm:CategoryHeaderViewModel}">
                                                                <Grid Margin="0,4,0,2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding HeaderText}" FontWeight="SemiBold" FontSize="13"
                                                                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                                                    <ComboBox Grid.Column="1" Width="160" Height="24" FontSize="11" Margin="8,0,4,0"
                                                                              Visibility="{Binding ShowCombo, Converter={StaticResource BoolToVis}}"
                                                                              ItemsSource="{Binding Options}" DisplayMemberPath="Label"
                                                                              SelectedItem="{Binding Selected}"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </Expander.HeaderTemplate>
                                                        <ItemsPresenter Margin="15,3,0,3"/>
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AppRowViewModel}">
                                <!-- Каждая строка — две выровненные по всему списку зоны:
                                     слева иконка+чекбокс+имя (SharedSizeGroup — ширина по
                                     самому длинному имени во всём каталоге), справа — все
                                     действия этого же приложения (избранное/версия/Play/
                                     альтернатива/удаление). Один DataTemplate на все строки —
                                     кнопки автоматически появляются у любого нового
                                     приложения (обновление каталога, добавленное вручную),
                                     без правок кода. -->
                                <Grid Margin="{Binding RowMargin}" HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="CatalogRowName"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Image Width="20" Height="20" Margin="0,0,6,0"
                                               Stretch="Uniform" Source="{Binding Icon}" VerticalAlignment="Center"/>

                                        <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsSelectable}"
                                                  AutomationProperties.AutomationId="{Binding CheckBoxAutomationId}"
                                                  VerticalAlignment="Center"/>

                                        <TextBlock Text="{Binding DisplayName}" Foreground="{Binding RowBrush}"
                                                   ToolTip="{Binding StatusTooltip}" VerticalAlignment="Center"
                                                   Margin="4,0,0,0" Cursor="Hand">
                                            <TextBlock.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.OpenCardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                              CommandParameter="{Binding}"/>
                                            </TextBlock.InputBindings>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="14,0,0,0">
                                        <Button Content="{Binding FavoriteGlyph}" Width="20" Height="20"
                                                Background="Transparent" BorderThickness="0" FontSize="14" Padding="0"
                                                Foreground="Gold" Cursor="Hand"
                                                ToolTip="{Binding FavoriteTooltip}"
                                                Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>

                                        <ComboBox Width="95" Height="22" Margin="4,0,0,0" FontSize="10"
                                                  VerticalAlignment="Center"
                                                  Visibility="{Binding ShowVersionCombo, Converter={StaticResource BoolToVis}}"
                                                  IsEnabled="{Binding IsVersionComboEnabled}"
                                                  ItemsSource="{Binding VersionOptions}"
                                                  SelectedItem="{Binding SelectedVersionOption}"/>

                                        <!-- ▶ Play — только когда приложение установлено И резолвер
                                             нашёл exe (HKLM App Paths/системный Start Menu/
                                             InstallLocation), см. Services/AppLaunchResolver.cs.
                                             Fail-closed: не нашли — не гадаем. -->
                                        <Button Content="▶" Width="22" Height="22" Margin="4,0,0,0"
                                                Command="{Binding LaunchCommand}"
                                                Visibility="{Binding CanLaunch, Converter={StaticResource BoolToVis}}"
                                                Background="{StaticResource BrandGreen}" Foreground="#06130D"
                                                ToolTip="Запустить"/>

                                        <Button Content="🔄" Width="24" Height="24" Margin="4,0,0,0"
                                                Command="{Binding DataContext.SuggestAlternativeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding ShowSuggestButton, Converter={StaticResource BoolToVis}}"
                                                Background="#FF8C00" Foreground="White" FontSize="12"
                                                ToolTip="Предложить альтернативный источник"/>

                                        <Button Content="❌" Width="20" Height="20" Margin="4,0,0,0"
                                                Command="{Binding DataContext.RemoveUserAppCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding IsUserAdded, Converter={StaticResource BoolToVis}}"
                                                Background="#640000" Foreground="White" FontSize="10" Padding="0"
                                                ToolTip="Удалить из списка"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </GroupBox>

        <!-- Правая панель: управление -->
        <ScrollViewer Grid.Row="0" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <GroupBox Header="Инструменты каталога">
                    <StackPanel>
                        <Button x:Name="btnCheckUpdates" Content="Проверить обновления" Height="35" Margin="3"
                                Command="{Binding CheckUpdatesCommand}"/>
                        <Button x:Name="btnRefreshCatalog" Content="Обновить каталог" Height="35" Margin="3"
                                Command="{Binding RefreshCatalogCommand}"/>
                        <Button x:Name="btnRefreshAvailability" Content="Проверить доступность" Height="35" Margin="3"
                                Command="{Binding RefreshAvailabilityCommand}"/>
                        <Button x:Name="btnClearAllUserApps" Content="Очистить добавленные" Height="35" Margin="3"
                                Foreground="{StaticResource StatusDanger}"
                                Command="{Binding ClearAllUserAppsCommand}"/>
                        <Separator Margin="3,4"/>
                        <Button x:Name="btnExportList" Content="Экспорт списка" Height="32" Margin="3"
                                ToolTip="Сохранить выбранные приложения в JSON" Command="{Binding ExportListCommand}"/>
                        <Button x:Name="btnImportList" Content="Импорт списка" Height="32" Margin="3"
                                ToolTip="Загрузить список приложений из JSON" Command="{Binding ImportListCommand}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Пресеты -->
                <GroupBox Header="📋 Пресеты" Margin="0,10,0,0">
                    <StackPanel>
                        <Button x:Name="btnSavePreset"
                                Content="{Binding SavePresetLabel}"
                                Height="32" Margin="3"
                                Command="{Binding SavePresetCommand}"
                                ToolTip="Сохранить отмеченные приложения как пресет"/>

                        <ItemsControl x:Name="lstPresets" ItemsSource="{Binding Presets}" Margin="3,4,3,2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2" Padding="8,6"
                                            Background="{DynamicResource CardBackground}"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding AppCountLabel}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextSecondary}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="→" Width="26" Height="26" Padding="0" FontSize="13" Margin="2,0,0,0"
                                                        ToolTip="Применить пресет"
                                                        Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="✏" Width="26" Height="26" Padding="0" FontSize="11" Margin="2,0,0,0"
                                                        ToolTip="Изменить название и описание"
                                                        Command="{Binding DataContext.RenamePresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="↻" Width="26" Height="26" Padding="0" FontSize="12" Margin="2,0,0,0"
                                                        ToolTip="Применить пресет и обновить состав"
                                                        Command="{Binding DataContext.UpdateAppsPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="✕" Width="26" Height="26" Padding="0" FontSize="11" Margin="2,0,0,0"
                                                        Background="Transparent" Foreground="{DynamicResource TextSecondary}" BorderThickness="0"
                                                        ToolTip="Удалить пресет"
                                                        Command="{Binding DataContext.DeletePresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Нет сохранённых пресетов"
                                   FontSize="11" Margin="6,2,6,4"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding PresetsEmpty, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="💾 Диск установки" Margin="0,10,0,0">
                    <StackPanel>
                        <ComboBox x:Name="cmbAvailableDisks" Height="28"
                                  ItemsSource="{Binding AvailableDisks}" DisplayMemberPath="Space"
                                  SelectedItem="{Binding SelectedDisk}"/>
                        <TextBlock Text="{Binding SpaceStatus}" FontSize="10" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        <ProgressBar x:Name="installProgressBar" Height="8" Margin="0,5,0,0" Minimum="0" Maximum="100"
                                     Value="{Binding OverallProgressPercentage}"/>
                        <TextBlock x:Name="txtOverallStatus" Text="{Binding InstallStatusText}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="📊 Прогресс установки" Margin="0,10,0,0" Height="160">
                    <ListBox x:Name="lstAppProgress" ItemsSource="{Binding InstallProgress}"
                             Background="{DynamicResource CardBackground}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4,3"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding AppName}"
                                               FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Status}" Grid.Column="1"
                                               FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                               Margin="6,0,0,0"/>
                                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                                 Height="4" Margin="0,3,0,0"
                                                 Value="{Binding Percentage}"
                                                 Background="{DynamicResource BorderBrush}"
                                                 Foreground="{DynamicResource AccentColor}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0" Padding="14,10"
                Background="{StaticResource SurfaceCard}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="7" Effect="{StaticResource PanelShadowEffect}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ВЫБРАННЫЕ ПРИЛОЖЕНИЯ" Style="{StaticResource EyebrowStyle}"/>
                    <TextBlock x:Name="txtSelectionBar"
                               Text="{Binding SelectedCount, StringFormat='Выбрано приложений: {0}'}"
                               FontSize="12" Margin="0,3,0,0"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
                <Button x:Name="btnCancelInstall" Grid.Column="1" Content="Отмена" Height="38" MinWidth="90"
                        Margin="0,0,8,0" Foreground="{StaticResource StatusDanger}"
                        Command="{Binding CancelInstallCommand}"/>
                <Button x:Name="btnInstall" Grid.Column="2"
                        Height="38" MinWidth="190"
                        Background="{StaticResource BrandGreen}" Foreground="#06130D"
                        Effect="{StaticResource BrandAuraEffect}"
                        Command="{Binding InstallSelectedCommand}">
                    <!-- StringFormat молча игнорируется, когда целевое свойство биндинга —
                         object (Button.Content), а не string: показывало голое число вместо
                         "Установить (N)". Вложенный TextBlock.Text (string) форматирует верно. -->
                    <TextBlock Text="{Binding SelectedCount, StringFormat='Установить ({0})'}"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
