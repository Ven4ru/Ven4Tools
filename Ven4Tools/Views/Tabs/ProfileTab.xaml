<UserControl x:Class="Ven4Tools.Views.Tabs.ProfileTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="AchievementCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Width" Value="145"/>
            <Setter Property="Height" Value="110"/>
        </Style>
        <Style x:Key="MedalCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Width" Value="110"/>
        </Style>
        <Style x:Key="PaletteBtn" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24" MaxWidth="860">

            <!-- ── Header ─────────────────────────────────────────────────────── -->
            <TextBlock Text="🏆 Достижения"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,20"/>

            <!-- ── Level card ─────────────────────────────────────────────────── -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Level icon -->
                    <Border Grid.Column="0" Width="72" Height="72" CornerRadius="36"
                            Background="{DynamicResource AccentColor}" Margin="0,0,20,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="txtLevelIcon" Text="🌱" FontSize="32"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Level info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock x:Name="txtLevelName" Text="Новичок"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <Border Background="{DynamicResource AccentColor}"
                                    CornerRadius="10" Padding="8,2" Margin="10,4,0,4"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="txtPoints" Text="0 очков"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>
                        <ProgressBar x:Name="progressLevel" Height="8" Minimum="0" Maximum="100"
                                     Value="0" Margin="0,4,0,6"
                                     Foreground="{DynamicResource AccentColor}"
                                     Background="{DynamicResource BorderBrush}">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ProgressBar">
                                                <Border CornerRadius="4"
                                                        Background="{TemplateBinding Background}">
                                                    <Border x:Name="PART_Indicator"
                                                            CornerRadius="4"
                                                            Background="{TemplateBinding Foreground}"
                                                            HorizontalAlignment="Left"
                                                            Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Converter={x:Null}}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>
                        <TextBlock x:Name="txtNextLevel" FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Text="До следующего уровня: —"/>
                    </StackPanel>

                    <!-- Stats column -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
                            <TextBlock Text="📦 " FontSize="13"/>
                            <TextBlock x:Name="txtInstallCount" Text="0"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text=" установлено" FontSize="13"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
                            <TextBlock Text="🔄 " FontSize="13"/>
                            <TextBlock x:Name="txtUpdateCount" Text="0"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text=" обновлено" FontSize="13"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="⭐ " FontSize="13"/>
                            <TextBlock x:Name="txtVisitCount" Text="0"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text=" посещений" FontSize="13"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Medals ─────────────────────────────────────────────────────── -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Медали" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>
                    <WrapPanel x:Name="panelMedals"/>
                </StackPanel>
            </Border>

            <!-- ── Achievements ───────────────────────────────────────────────── -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <TextBlock Text="Достижения" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="txtAchievCount" HorizontalAlignment="Right"
                                   FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <WrapPanel x:Name="panelAchievements"/>
                </StackPanel>
            </Border>

            <!-- ── Color palette ─────────────────────────────────────────────── -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="🎨 Цветовая схема" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>
                    <TextBlock Text="Выберите акцентный цвет интерфейса"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12" Margin="0,0,0,12"/>
                    <WrapPanel x:Name="panelPalette"/>
                    <TextBlock x:Name="txtCurrentPalette" Margin="0,10,0,0"
                               FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Border>

            <!-- ── Leaderboard ────────────────────────────────────────────────── -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <TextBlock Text="🏅 Таблица лидеров" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <Border Background="{DynamicResource BorderBrush}" CornerRadius="8"
                                Padding="8,3" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="Скоро" FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </Border>
                    </Grid>
                    <ItemsControl x:Name="listLeaderboard">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Rank}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               FontSize="14" Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Points}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentColor}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
