<UserControl x:Class="Ven4Tools.Views.Tabs.DriversTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="🖥️ Драйверы" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextSecondary}" FontSize="12">
                    Сканирование устройств через WMI. Для известных производителей — установка через winget. Для остальных — Snappy Driver Installer.
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button x:Name="btnScanDrivers" Content="🔍 Сканировать"
                        Height="34" Padding="14,0" Click="BtnScanDrivers_Click"/>
                <Button x:Name="btnInstallSDI" Content="📦 Открыть SDI"
                        Height="34" Padding="10,0" Margin="8,0,0,0"
                        Click="BtnInstallSDI_Click"/>
            </StackPanel>
        </Grid>

        <!-- Stats bar -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackground}"
                CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="txtDriverStats" Text="Нажмите «Сканировать» для проверки устройств"
                           Foreground="{DynamicResource TextSecondary}" FontSize="12"
                           VerticalAlignment="Center"/>
                <ProgressBar x:Name="progressScan" Width="120" Height="6" Margin="16,0,0,0"
                             IsIndeterminate="True" Visibility="Collapsed"
                             Foreground="{DynamicResource AccentColor}"/>
            </StackPanel>
        </Border>

        <!-- Device list -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackground}"
                CornerRadius="10" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="lstDevices">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" Margin="2,1" CornerRadius="7">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource BorderBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                               FontSize="18" Margin="0,0,10,0"
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}">
                                            <Run Text="{Binding DeviceClass}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding StatusText}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Winget ID badge if known -->
                                    <Border Grid.Column="2" CornerRadius="5" Padding="7,3"
                                            Background="{DynamicResource BorderBrush}"
                                            VerticalAlignment="Center" Margin="8,0"
                                            Visibility="{Binding WingetBadgeVisibility}">
                                        <TextBlock Text="{Binding WingetId}" FontSize="10"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </Border>

                                    <!-- Install button -->
                                    <Button Grid.Column="3" Content="⬇️ Установить"
                                            Height="28" Padding="10,0" FontSize="11"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding InstallButtonVisibility}"
                                            Tag="{Binding}"
                                            Click="BtnInstallDriver_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Log -->
        <TextBox x:Name="txtDriverLog" Grid.Row="3" Height="80" Margin="0,10,0,0"
                 Background="{DynamicResource CardBackground}"
                 Foreground="#00FF00" FontFamily="Consolas" FontSize="10"
                 IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Visibility="Collapsed"/>
    </Grid>
</UserControl>
