<Window x:Class="Ven4Tools.Views.LocalInstallerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить установщик" Height="280" Width="440"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">
    <StackPanel Margin="20">
        <TextBlock Text="📦 Добавить локальный установщик" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>

        <TextBlock Text="Путь к файлу:" Foreground="{DynamicResource TextSecondary}"
                   FontSize="11" Margin="0,0,0,4"/>
        <Border Background="{DynamicResource CardBackground}" CornerRadius="6" Padding="8,6" Margin="0,0,0,12">
            <TextBlock x:Name="txtFilePath" Foreground="{DynamicResource TextSecondary}"
                       FontSize="11" TextTrimming="CharacterEllipsis"/>
        </Border>

        <TextBlock Text="Название программы:" Foreground="{DynamicResource TextSecondary}"
                   FontSize="11" Margin="0,0,0,4"/>
        <TextBox x:Name="txtName" Height="32" Margin="0,0,0,12"
                 Background="{DynamicResource CardBackground}"
                 Foreground="{DynamicResource TextPrimary}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 VerticalContentAlignment="Center" Padding="8,0"/>

        <TextBlock Text="Категория:" Foreground="{DynamicResource TextSecondary}"
                   FontSize="11" Margin="0,0,0,4"/>
        <ComboBox x:Name="cmbCategory" Height="32" Margin="0,0,0,20"
                  Background="{DynamicResource CardBackground}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnCancel" Content="Отмена" Width="90" Height="32"
                    Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="btnOk" Content="✅ Добавить" Width="110" Height="32"
                    Background="{DynamicResource AccentColor}" Foreground="White"
                    FontWeight="SemiBold" Click="BtnOk_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
