<Window x:Class="Ven4Tools.Views.EulaConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лицензионные соглашения" Height="520" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="txtHeader" FontSize="15" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="2"
                   Text="Лицензионные соглашения выбранных обновлений — прокрутите и ознакомьтесь:"
                   FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>

        <Border Grid.Row="4"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                <TextBox x:Name="txtEula"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         BorderThickness="0" Background="Transparent"
                         Foreground="{DynamicResource TextPrimary}"
                         FontSize="12"
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnDecline" Grid.Column="1" Content="Отклонить" Height="36" Padding="20,0" Margin="0,0,8,0"
                    Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Click="BtnDecline_Click"/>
            <Button x:Name="btnAccept" Grid.Column="2" Content="Принять и установить" Height="36" Padding="20,0"
                    Background="{DynamicResource AccentColor}" Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0" Click="BtnAccept_Click"/>
        </Grid>
    </Grid>
</Window>
