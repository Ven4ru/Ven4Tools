<Window x:Class="Ven4Tools.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Width="520" Height="420"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ResizeMode="NoResize">
    <Border Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image x:Name="imgMascot"
                   Grid.Row="0"
                   Source="/Resources/Mascots/loading.png"
                   Stretch="Uniform"
                   Margin="20,20,20,8"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <StackPanel Grid.Row="1" Margin="30,0,30,20">
                <TextBlock x:Name="txtStatus"
                           Text="Запуск..."
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}"
                           Margin="0,0,0,8"/>
                <ProgressBar x:Name="progressBar"
                             Height="4" IsIndeterminate="True"
                             Foreground="{DynamicResource AccentColor}"
                             Background="{DynamicResource BorderBrush}"/>
                <Button x:Name="btnSkip"
                        Content="Пропустить"
                        Click="BtnSkip_Click"
                        HorizontalAlignment="Right"
                        Width="110" Height="26"
                        FontSize="11" FontWeight="Normal"
                        Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
