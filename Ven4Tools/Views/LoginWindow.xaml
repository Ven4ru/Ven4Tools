<Window x:Class="Ven4Tools.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ven4Tools — Аккаунт"
        Width="860" Height="710"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель — баннер -->
        <Border Grid.Column="0" ClipToBounds="True" Background="#0A1A0A">
            <Image Source="pack://application:,,,/Resources/Mascots/login.png"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        </Border>

        <!-- Правая панель — форма -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="40,32,40,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <StackPanel Grid.Row="0" Margin="0,0,0,28" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtLoginIcon" Text="👤" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtTitle" Text="Войти в аккаунт"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Переключатель режима -->
                <Grid x:Name="panelModeSwitch" Grid.Row="1" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnModeLogin" Grid.Column="0" Content="Войти"
                            Height="36" Margin="0,0,4,0"
                            Background="{DynamicResource AccentColor}"
                            Foreground="White"
                            Click="BtnModeLogin_Click"/>
                    <Button x:Name="btnModeRegister" Grid.Column="1" Content="Регистрация"
                            Height="36" Margin="4,0,0,0"
                            Click="BtnModeRegister_Click"/>
                </Grid>

                <!-- Форма -->
                <StackPanel Grid.Row="2">

                    <!-- Имя (только регистрация) -->
                    <StackPanel x:Name="panelName" Visibility="Collapsed" Margin="0,0,0,12">
                        <TextBlock Text="Имя" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <TextBox x:Name="txtName" Height="36" Padding="10,8" FontSize="13"
                                 Background="{DynamicResource CardBackground}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"
                                 CaretBrush="{DynamicResource TextPrimary}"/>
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Email" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <TextBox x:Name="txtEmail" Height="36" Padding="10,8" FontSize="13"
                                 Background="{DynamicResource CardBackground}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"
                                 CaretBrush="{DynamicResource TextPrimary}"/>
                    </StackPanel>

                    <!-- Пароль -->
                    <StackPanel x:Name="panelPassword" Margin="0,0,0,12">
                        <TextBlock Text="Пароль" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <PasswordBox x:Name="txtPassword" Height="36" Padding="10,8"
                                     FontSize="13"
                                     Background="{DynamicResource CardBackground}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     CaretBrush="{DynamicResource TextPrimary}"/>
                    </StackPanel>

                    <!-- Подтверждение пароля (только регистрация) -->
                    <StackPanel x:Name="panelConfirm" Visibility="Collapsed" Margin="0,0,0,12">
                        <TextBlock Text="Подтвердите пароль" FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <PasswordBox x:Name="txtConfirm" Height="36" Padding="10,8"
                                     FontSize="13"
                                     Background="{DynamicResource CardBackground}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     CaretBrush="{DynamicResource TextPrimary}"/>
                    </StackPanel>

                    <!-- Ошибка -->
                    <TextBlock x:Name="txtError" Text=""
                               Foreground="#FF6B6B" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,12"
                               Visibility="Collapsed"/>

                    <!-- Кнопка submit -->
                    <Button x:Name="btnSubmit" Content="Войти"
                            Height="40" Margin="0,4,0,0"
                            Background="{DynamicResource AccentColor}"
                            Foreground="White"
                            FontSize="14"
                            Click="BtnSubmit_Click"/>

                    <!-- Забыли пароль? (только login-режим) -->
                    <Button x:Name="btnForgotPassword" Content="Забыли пароль?"
                            Height="28" Margin="0,8,0,0"
                            HorizontalAlignment="Center"
                            Background="Transparent"
                            Foreground="{DynamicResource AccentColor}"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Click="BtnForgotPassword_Click"/>

                    <!-- Назад (только forgot-режим) -->
                    <Button x:Name="btnBack" Content="← Назад"
                            Height="28" Margin="0,8,0,0"
                            HorizontalAlignment="Center"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondary}"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Visibility="Collapsed"
                            Click="BtnBack_Click"/>

                    <!-- Письмо отправлено (только forgot-режим) -->
                    <StackPanel x:Name="panelForgotSuccess" Visibility="Collapsed" Margin="0,12,0,0">
                        <TextBlock Text="📧 Письмо отправлено. Проверьте почту."
                                   Foreground="#4CAF50" FontSize="13"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>

                    <!-- Разделитель -->
                    <Grid x:Name="panelDivider" Margin="0,20,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Separator Grid.Column="0" VerticalAlignment="Center"
                                   Background="{DynamicResource BorderBrush}"/>
                        <TextBlock Grid.Column="1" Text="или" Margin="10,0"
                                   FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                        <Separator Grid.Column="2" VerticalAlignment="Center"
                                   Background="{DynamicResource BorderBrush}"/>
                    </Grid>

                    <!-- Яндекс -->
                    <Button x:Name="btnYandex" Height="40"
                            Background="#FC3F1D" Foreground="White"
                            BorderThickness="0" FontSize="14"
                            Click="BtnYandex_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Я" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Войти через Яндекс" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
