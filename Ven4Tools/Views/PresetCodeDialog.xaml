<Window x:Class="Ven4Tools.Views.PresetCodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Применить пресет по коду" Height="185" Width="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📥 Введите код пресета"
                   FontSize="14" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>

        <TextBox x:Name="txtCode" Grid.Row="1"
                 Height="32" Margin="0,0,0,12"
                 Background="{DynamicResource CardBackground}"
                 Foreground="{DynamicResource TextPrimary}"
                 VerticalContentAlignment="Center" Padding="8,0"
                 FontFamily="Consolas" FontSize="13"
                 MaxLength="16"
                 KeyDown="TxtCode_KeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Width="70" Height="30" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Загрузить" Width="80" Height="30"
                    Background="{DynamicResource AccentColor}" Foreground="White"
                    BorderThickness="0" Click="Load_Click"/>
        </StackPanel>
    </Grid>
</Window>
