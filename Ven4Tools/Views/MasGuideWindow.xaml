<Window x:Class="Ven4Tools.Views.MasGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление лицензией"
        Width="460" SizeToContent="Height"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#0d1117"
        Foreground="#e2e8f0"
        FontFamily="Inter, Segoe UI, sans-serif">

    <Window.Resources>
        <Style x:Key="StepCard" TargetType="Border">
            <Setter Property="Background" Value="#11161f"/>
            <Setter Property="BorderBrush" Value="#1e2a38"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="StepNum" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#0d4f3c"/>
            <Setter Property="BorderBrush" Value="#4ade80"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="StepTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#e2e8f0"/>
        </Style>
        <Style x:Key="StepBody" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Заголовок -->
        <StackPanel Margin="0,0,0,18">
            <TextBlock x:Name="txtWindowTitle"
                       Text="🔑 Управление лицензией Windows"
                       FontSize="16" FontWeight="Bold" Foreground="#e2e8f0"/>
            <TextBlock Text="Следуйте инструкции — браузер уже открыт"
                       FontSize="12" Foreground="#94a3b8" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Шаг 1 -->
        <Border Style="{StaticResource StepCard}"
                BorderBrush="#1a3a1a">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource StepNum}" VerticalAlignment="Top" Margin="0,1,14,0">
                    <TextBlock Text="1" FontSize="12" FontWeight="Bold" Foreground="#4ade80"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource StepTitle}" Text="🌐 Браузер открыт"/>
                    <TextBlock Style="{StaticResource StepBody}"
                               x:Name="txtStep1Body"
                               Text="На сайте massgrave.dev найдите раздел активации Windows и скопируйте команду (обычно начинается с irm или iwr)."/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Шаг 2 -->
        <Border Style="{StaticResource StepCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource StepNum}" VerticalAlignment="Top" Margin="0,1,14,0">
                    <TextBlock Text="2" FontSize="12" FontWeight="Bold" Foreground="#4ade80"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource StepTitle}" Text="💻 Откройте PowerShell"/>
                    <TextBlock Style="{StaticResource StepBody}"
                               Text="Нажмите кнопку ниже или вручную: Win + X → Windows Terminal (Администратор)."/>
                    <Button x:Name="btnOpenTerminal"
                            Content="💻 Открыть PowerShell"
                            Height="34" Width="200" HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            Background="#1a3a1a" Foreground="White"
                            BorderBrush="#4ade80" BorderThickness="1"
                            FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Шаг 3 -->
        <Border Style="{StaticResource StepCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource StepNum}" VerticalAlignment="Top" Margin="0,1,14,0">
                    <TextBlock Text="3" FontSize="12" FontWeight="Bold" Foreground="#4ade80"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource StepTitle}" Text="⌨️ Вставьте и запустите команду"/>
                    <TextBlock Style="{StaticResource StepBody}"
                               Text="В окне PowerShell нажмите Ctrl+V, затем Enter. Следуйте инструкциям на экране — процесс займёт около минуты."/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Закрыть -->
        <Button x:Name="btnClose" Content="Закрыть"
                Height="34" Width="100" HorizontalAlignment="Right"
                Margin="0,6,0,0"
                Background="Transparent" Foreground="#94a3b8"
                BorderBrush="#1e2a38" BorderThickness="1"/>

    </StackPanel>
</Window>
