<Window x:Class="Ven4Tools.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource prof_title}" Height="560" Width="660"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Tab header style -->
        <Style x:Key="ProfTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tab"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,1,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tab" Property="Background" Value="{DynamicResource ContentBackground}"/>
                                <Setter TargetName="tab" Property="BorderThickness" Value="0,2,1,0"/>
                                <Setter TargetName="tab" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tab" Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="tabControl" Grid.Row="0"
                    Background="{DynamicResource ContentBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">

            <!-- ===== CATALOG TAB ===== -->
            <TabItem Header="{DynamicResource prof_tab_catalog}" Style="{StaticResource ProfTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,8,24,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource prof_catalog_mode_label}" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <RadioButton x:Name="rbBasic" GroupName="CatalogMode" Margin="0,0,16,0">
                                <TextBlock Text="{DynamicResource prof_catalog_mode_basic}"/>
                            </RadioButton>
                            <RadioButton x:Name="rbExtended" GroupName="CatalogMode" Margin="0,0,16,0">
                                <TextBlock Text="{DynamicResource prof_catalog_mode_extended}"/>
                            </RadioButton>
                            <RadioButton x:Name="rbFull" GroupName="CatalogMode">
                                <TextBlock Text="{DynamicResource prof_catalog_mode_full}"/>
                            </RadioButton>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource prof_catalog_sort_label}" Style="{StaticResource SectionHeader}"/>
                        <ComboBox x:Name="cmbSort" Width="220" HorizontalAlignment="Left">
                            <ComboBoxItem x:Name="sortAlpha" Content="{DynamicResource prof_catalog_sort_alpha}"/>
                            <ComboBoxItem x:Name="sortCategory" Content="{DynamicResource prof_catalog_sort_category}"/>
                            <ComboBoxItem x:Name="sortPopularity" Content="{DynamicResource prof_catalog_sort_popularity}"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource SectionHeader}">Фильтры</TextBlock>
                        <CheckBox x:Name="chkHideInstalled" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_catalog_hide_installed}"/>
                        </CheckBox>
                        <CheckBox x:Name="chkFreeOnly" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_catalog_free_only}"/>
                        </CheckBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== UI TAB ===== -->
            <TabItem Header="{DynamicResource prof_tab_ui}" Style="{StaticResource ProfTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,8,24,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource prof_ui_theme_label}" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbDark" GroupName="Theme" Margin="0,0,16,0"
                                         Checked="RbTheme_Checked">
                                <TextBlock Text="{DynamicResource prof_ui_theme_dark}"/>
                            </RadioButton>
                            <RadioButton x:Name="rbLight" GroupName="Theme"
                                         Checked="RbTheme_Checked">
                                <TextBlock Text="{DynamicResource prof_ui_theme_light}"/>
                            </RadioButton>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource prof_ui_lang_label}" Style="{StaticResource SectionHeader}"/>
                        <ComboBox x:Name="cmbLang" Width="240" HorizontalAlignment="Left">
                            <ComboBoxItem x:Name="langAuto" Content="{DynamicResource prof_ui_lang_auto}" Tag="auto"/>
                            <ComboBoxItem x:Name="langRu" Content="{DynamicResource prof_ui_lang_ru}" Tag="ru"/>
                            <ComboBoxItem x:Name="langEn" Content="{DynamicResource prof_ui_lang_en}" Tag="en"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource SectionHeader}">Отображение</TextBlock>
                        <CheckBox x:Name="chkCompact" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_ui_compact}"/>
                        </CheckBox>
                        <CheckBox x:Name="chkDescriptions" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_ui_descriptions}"/>
                        </CheckBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== INSTALL TAB ===== -->
            <TabItem Header="{DynamicResource prof_tab_install}" Style="{StaticResource ProfTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,8,24,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}">Поведение</TextBlock>
                        <CheckBox x:Name="chkSilent" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_install_silent}"/>
                        </CheckBox>
                        <CheckBox x:Name="chkAutoDeps" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_install_auto_deps}"/>
                        </CheckBox>

                        <TextBlock Text="{DynamicResource prof_install_folder_label}" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtInstallFolder" Height="32" Margin="0,0,6,0"
                                     VerticalContentAlignment="Center" Padding="6,0"
                                     FontSize="12"/>
                            <Button Grid.Column="1" Height="32" Width="90"
                                    Content="{DynamicResource prof_install_folder_browse}"
                                    FontWeight="Normal"
                                    Click="BtnBrowseFolder_Click"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== NOTIFICATIONS TAB ===== -->
            <TabItem Header="{DynamicResource prof_tab_notif}" Style="{StaticResource ProfTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,8,24,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}">Обновления</TextBlock>
                        <CheckBox x:Name="chkNotifUpdates" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_notif_app_updates}"/>
                        </CheckBox>
                        <CheckBox x:Name="chkNotifNew" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_notif_new_apps}"/>
                        </CheckBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== PRIVACY TAB ===== -->
            <TabItem Header="{DynamicResource prof_tab_privacy}" Style="{StaticResource ProfTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,8,24,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}">Синхронизация</TextBlock>
                        <CheckBox x:Name="chkSyncFavorites" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_privacy_sync_favorites}"/>
                        </CheckBox>
                        <CheckBox x:Name="chkHistory" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_privacy_history}"/>
                        </CheckBox>

                        <TextBlock Style="{StaticResource SectionHeader}">Данные</TextBlock>
                        <CheckBox x:Name="chkStats" Margin="0,4">
                            <TextBlock Text="{DynamicResource prof_privacy_stats}"/>
                        </CheckBox>
                        <TextBlock Text="{DynamicResource prof_privacy_stats_hint}"
                                   FontSize="11" Margin="20,0,0,0"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Footer buttons -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Button HorizontalAlignment="Left" Width="130"
                        Content="{DynamicResource prof_reset}"
                        FontWeight="Normal"
                        Click="BtnReset_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="90" Margin="0,0,8,0"
                            Content="{DynamicResource prof_cancel}"
                            FontWeight="Normal"
                            Click="BtnCancel_Click"/>
                    <Button Width="110"
                            Content="{DynamicResource prof_save}"
                            Background="{DynamicResource AccentColor}"
                            Foreground="White"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
