<Window x:Class="Ven4Tools.Views.CategorySelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ven4Tools" Height="520" Width="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        ShowInTaskbar="False">

    <Grid Margin="32,28,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{DynamicResource cat_window_title}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{DynamicResource cat_window_subtitle}"
                       FontSize="13" Margin="0,6,0,0"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Cards -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Basic card -->
            <Border x:Name="cardBasic" Grid.Column="0"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                    CornerRadius="10" Cursor="Hand"
                    MouseDown="Card_MouseDown" Tag="basic">
                <StackPanel Margin="16,20,16,20">
                    <TextBlock Text="{DynamicResource cat_basic_icon}"
                               FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource cat_basic_title}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource cat_basic_sub}"
                               FontSize="11" Margin="0,4,0,12"
                               Foreground="{DynamicResource AccentColor}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource cat_basic_desc}"
                               FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,12,0,10"/>
                    <TextBlock FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}">
                        • Браузеры&#x0a;• Офис&#x0a;• Мультимедиа&#x0a;• Системные утилиты
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Extended card -->
            <Border x:Name="cardExtended" Grid.Column="2"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                    CornerRadius="10" Cursor="Hand"
                    MouseDown="Card_MouseDown" Tag="extended">
                <StackPanel Margin="16,20,16,20">
                    <TextBlock Text="{DynamicResource cat_ext_icon}"
                               FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource cat_ext_title}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource cat_ext_sub}"
                               FontSize="11" Margin="0,4,0,12"
                               Foreground="{DynamicResource AccentColor}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource cat_ext_desc}"
                               FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,12,0,10"/>
                    <TextBlock FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}">
                        • Всё базовое&#x0a;• Разработка&#x0a;• Графика&#x0a;• Мессенджеры
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Full card -->
            <Border x:Name="cardFull" Grid.Column="4"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                    CornerRadius="10" Cursor="Hand"
                    MouseDown="Card_MouseDown" Tag="full">
                <StackPanel Margin="16,20,16,20">
                    <TextBlock Text="{DynamicResource cat_full_icon}"
                               FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource cat_full_title}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource cat_full_sub}"
                               FontSize="11" Margin="0,4,0,12"
                               Foreground="{DynamicResource AccentColor}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource cat_full_desc}"
                               FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,12,0,10"/>
                    <TextBlock FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}">
                        • Все категории&#x0a;• Игровые сервисы&#x0a;• Драйверпаки&#x0a;• Пользовательские
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Button x:Name="btnContinue" Grid.Row="2"
                Content="{DynamicResource cat_continue}"
                Height="42" Width="200" Margin="0,20,0,0"
                HorizontalAlignment="Center"
                IsEnabled="False"
                Background="{DynamicResource AccentColor}"
                Foreground="White" FontSize="14" FontWeight="Bold"
                Click="BtnContinue_Click"/>
    </Grid>
</Window>
